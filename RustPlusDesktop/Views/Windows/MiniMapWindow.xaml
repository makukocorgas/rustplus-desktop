<Window x:Class="RustPlusDesk.MiniMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:views="clr-namespace:RustPlusDesk.Views"
        Title="{DynamicResource MiniMap}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="260" Height="260">
    <Grid>
        <!-- Container that has the exact size of the Map shape -->
        <Grid x:Name="MapContainer" Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Runde / Eckige Mini-Map -->
            <Border x:Name="MapShapeBorder" CornerRadius="130" BorderBrush="#66000000" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Background>
                    <VisualBrush x:Name="MirrorBrush"
                                 Stretch="UniformToFill"
                                 AlignmentX="Center" AlignmentY="Center" />
                </Border.Background>
            </Border>

            <!-- Time Overlay -->
            <Border x:Name="TimeOverlayBorder" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,12" 
                    Background="#AA000000" 
                    CornerRadius="6" 
                    Padding="6,4" 
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Clock24" FontSize="12" Margin="0,0,4,0" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtServerTime" Text="{Binding ServerTime}" FontSize="12" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Settings Hover Area -->
            <Border x:Name="SettingsHoverBorder" Background="Transparent" Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <ui:Button x:Name="BtnSettings" 
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Top" 
                           Margin="10" 
                           Padding="4"
                           Appearance="Transparent"
                           Background="#88000000"
                           Foreground="White"
                           Click="BtnSettings_Click"
                           Icon="{ui:SymbolIcon Symbol=Settings24}"
                           Panel.ZIndex="10"/>
            </Border>
        </Grid>

        <!-- Settings Overlay -->
        <views:MiniMapSettingsOverlay x:Name="SettingsOverlay" Visibility="Collapsed" Panel.ZIndex="100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
