<UserControl x:Class="RustPlusDesk.Views.MiniMapSettingsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:p="clr-namespace:RustPlusDesk.Properties"
             mc:Ignorable="d" 
             Background="Transparent"
             Foreground="{DynamicResource TextPrimary}">

    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="12" 
            Padding="14">
        <StackPanel Width="180">
            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Map24" Margin="0,0,6,0" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" FontSize="16"/>
                    <TextBlock Text="{DynamicResource MiniMapSettings}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Button x:Name="BtnSettingsClose" 
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Center" 
                           Padding="4"
                           Appearance="Transparent"
                           Click="BtnSettingsClose_Click"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}"/>
            </Grid>

            <!-- Shape ComboBox -->
            <TextBlock Text="{DynamicResource Shape}" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbShape" SelectionChanged="CmbShape_SelectionChanged" Margin="0,0,0,12">
                <ComboBoxItem Content="{DynamicResource Circle}"/>
                <ComboBoxItem Content="{DynamicResource Square}"/>
                <ComboBoxItem Content="{DynamicResource Rectangle}"/>
            </ComboBox>

            <!-- Opacity Slider -->
            <TextBlock x:Name="LblOpacity" Text="Opacity: 100%" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <Slider x:Name="SliOpacity" Minimum="0.2" Maximum="1.0" Value="1.0" ValueChanged="SliOpacity_ValueChanged" Margin="0,0,0,12" IsSnapToTickEnabled="True" TickFrequency="0.05"/>

            <!-- Size Slider -->
            <TextBlock x:Name="LblSize" Text="Size: 100% (SHIFT+Mousewheel)" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <Slider x:Name="SliSize" Minimum="160" Maximum="800" Value="260" ValueChanged="SliSize_ValueChanged" Margin="0,0,0,12" IsSnapToTickEnabled="True" TickFrequency="10"/>

            <!-- Show Server Time CheckBox -->
            <CheckBox x:Name="ChkShowTime" Content="{DynamicResource ShowServerTime}" Checked="ChkShowTime_Changed" Unchecked="ChkShowTime_Changed" Style="{StaticResource DotCheckBox}" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
