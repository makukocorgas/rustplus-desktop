<Window x:Class="RustPlusDesk.Views.Windows.PremiumInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{x:Static p:Resources.PremiumFeatures}"
        Width="540" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.4" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <ui:SymbolIcon Symbol="Star24" Foreground="#FF3B30" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static p:Resources.PremiumFeatures}" FontSize="18" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TxtDescription"
                       Grid.Row="1"
                       TextWrapping="Wrap" 
                       FontSize="14" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       LineHeight="22" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button x:Name="BtnStopSync"
                           Content="Stop Sync"
                           Appearance="Secondary"
                           MinWidth="118"
                           Padding="14,0"
                           Margin="0,0,8,0"
                           Click="BtnStopSync_Click" />
                <ui:Button x:Name="BtnStayFree"
                           Content="Stay Free"
                           Appearance="Secondary"
                           MinWidth="118"
                           Padding="14,0"
                           Margin="0,0,8,0"
                           Click="BtnStayFree_Click" />
                <ui:Button x:Name="BtnSupportNow"
                           Content="Support Now"
                           Appearance="Primary"
                           MinWidth="138"
                           Padding="14,0"
                           Click="BtnSupportNow_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
