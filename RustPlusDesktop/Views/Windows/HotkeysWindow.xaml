<Window x:Class="RustPlusDesk.Views.HotkeysWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Hotkeys}"
        Width="660" Height="520"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Smooth Animated Label on Button Hover -->
        <Style x:Key="HoverTextOnlyOnParentHover" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ui:Button}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard Timeline.DesiredFrameRate="120">
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="100"
                                                 Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="6,0,2,0"
                                                    Duration="0:0:0.25">
                                    <ThicknessAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard Timeline.DesiredFrameRate="120">
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="0"
                                                    Duration="0:0:0.2">
                                    <ThicknessAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseIn"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentDark}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SurfaceAlt}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="2" 
            CornerRadius="12">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title & Close -->
                <RowDefinition Height="Auto"/> <!-- Description -->
                <RowDefinition Height="Auto"/> <!-- Options (Delay / Mode) -->
                <RowDefinition Height="*"/>    <!-- DataGrid -->
                <RowDefinition Height="Auto"/> <!-- Footer Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource Hotkeys}" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
                <Button Content="✕" 
                        HorizontalAlignment="Right" 
                        Click="BtnClose_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TextSubtle}"
                        FontSize="16"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="1" 
                       Text="{DynamicResource AssignGlobalHotkeys}"
                       Foreground="{DynamicResource TextSubtle}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <!-- Options Card -->
            <Border Grid.Row="2" 
                    Style="{StaticResource Card}" 
                    Background="{DynamicResource Surface}" 
                    BorderBrush="{DynamicResource CardBorder}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource HotkeyExecutionMode}" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <ComboBox x:Name="CbMode" Width="200" SelectionChanged="CbMode_SelectionChanged">
                            <ComboBoxItem x:Name="CbiSequential" Content="{DynamicResource HotkeySequential}"/>
                            <ComboBoxItem x:Name="CbiParallel" Content="{DynamicResource HotkeyParallel}"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="PanelDelay" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock x:Name="TxtDelayLabel" 
                                   Text="Toggle Delay: 150ms" 
                                   Foreground="{DynamicResource TextSubtle}"
                                   VerticalAlignment="Center"
                                   Width="140"
                                   Margin="0,0,10,0"/>
                        <Slider x:Name="SldDelay" 
                                Width="120"
                                Minimum="50" 
                                Maximum="1000" 
                                Value="150" 
                                TickFrequency="50" 
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="SldDelay_ValueChanged"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid Container -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource Surface}" 
                    BorderBrush="{DynamicResource CardBorder}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="8"
                    Margin="0,0,0,12">
                <DataGrid x:Name="GridDevices"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          ItemsSource="{Binding}"
                          Background="Transparent"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <!-- Warning indicator -->
                        <DataGridTemplateColumn Width="32">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon Symbol="Warning24" 
                                                   Foreground="#FF5252" 
                                                   Visibility="{Binding IsRegisteredWarningVisible, Converter={StaticResource BoolToVis}}"
                                                   ToolTip="{DynamicResource HotkeyWarningInUse}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Device Info (Combined Name, ID, and Status) -->
                        <DataGridTemplateColumn Header="{DynamicResource Device}" Width="2.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="4" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Modern switch/deleted icon -->
                                        <ui:SymbolIcon Symbol="Power24" 
                                                       FontSize="18" 
                                                       VerticalAlignment="Center" 
                                                       Margin="0,0,10,0">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                            <Setter Property="Symbol" Value="Dismiss24"/>
                                                            <Setter Property="Foreground" Value="#FF5252"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="ON">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <!-- Clean Device Name -->
                                            <TextBlock Text="{Binding DisplayName}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="13" 
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            
                                            <!-- Sub-info: ID & Status -->
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="ID: " 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource TextSubtle}"/>
                                                <TextBlock Text="{Binding EntityId}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource TextSubtle}"
                                                           Margin="0,0,12,0"/>
                                                
                                                <!-- Status label with color triggers -->
                                                <TextBlock Text="{Binding Status}" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="ON">
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="OFF">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="DELETED">
                                                                    <Setter Property="Foreground" Value="#FF5252"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Hotkey Badge Column -->
                        <DataGridTemplateColumn Header="{DynamicResource Hotkey}" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceAlt}" 
                                            BorderBrush="{DynamicResource CardBorder}" 
                                            BorderThickness="1" 
                                            CornerRadius="6" 
                                            Padding="8,4" 
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasHotkey, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:SymbolIcon Symbol="Keyboard24" 
                                                           FontSize="12" 
                                                           Margin="0,0,6,0" 
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Hotkey}" 
                                                       FontSize="11" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions Column -->
                        <DataGridTemplateColumn Header="" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <ui:Button Click="BtnSet_Click"
                                                   Appearance="Secondary"
                                                   Padding="6"
                                                   Margin="0,0,6,0"
                                                   ToolTip="{DynamicResource Set}"
                                                   VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Keyboard24" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Set}" Style="{StaticResource HoverTextOnlyOnParentHover}"/>
                                            </StackPanel>
                                        </ui:Button>
                                        <ui:Button Click="BtnClear_Click"
                                                   Appearance="Secondary"
                                                   Padding="6"
                                                   ToolTip="{DynamicResource Clear}"
                                                   IsEnabled="{Binding HasHotkey}"
                                                   VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Delete24" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Clear}" Style="{StaticResource HoverTextOnlyOnParentHover}"/>
                                            </StackPanel>
                                        </ui:Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{DynamicResource CloseDeactivate}"
                           Width="160" Margin="0,0,8,0"
                           Appearance="Secondary"
                           Click="BtnCloseDeactivate_Click"/>
                <ui:Button Content="{DynamicResource CloseActivate}"
                           Width="160"
                           Appearance="Primary"
                           Click="BtnCloseActivate_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
