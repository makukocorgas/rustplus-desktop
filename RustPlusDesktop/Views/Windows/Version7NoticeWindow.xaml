<Window x:Class="RustPlusDesk.Views.Windows.Version7NoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Rust+ Desktop &#x1F6E0;&#xFE0F; v7.0.0 Update"
        Width="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F1215"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.4" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161B22" CornerRadius="12,12,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#E8611A" CornerRadius="5" Padding="6,3" Margin="0,0,10,0">
                        <TextBlock Text="v7.0.0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Update700Title}" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="22,18,22,10">

                <TextBlock Text="{DynamicResource FeatureSummaryAdjustments}" FontSize="13" FontWeight="SemiBold"
                           Foreground="#E8611A" Margin="0,0,0,10"/>

                <!-- Feature list -->
                <Border Background="#161B22" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                    <StackPanel>
                        <!-- Bullet 1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Map24" Foreground="#E8611A" Margin="0,2,10,0" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="#D0D0D0" TextWrapping="Wrap" Width="350">
                                <Run FontWeight="SemiBold" Text="{DynamicResource Update700Title1}" Foreground="White"/><LineBreak/>
                                <Run Text="{DynamicResource Update700Desc1}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bullet 2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Cube24" Foreground="#E8611A" Margin="0,2,10,0" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="#D0D0D0" TextWrapping="Wrap" Width="350">
                                <Run FontWeight="SemiBold" Text="{DynamicResource Update700Title2}" Foreground="White"/><LineBreak/>
                                <Run Text="{DynamicResource Update700Desc2}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bullet 3 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Flash24" Foreground="#E8611A" Margin="0,2,10,0" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="#D0D0D0" TextWrapping="Wrap" Width="350">
                                <Run FontWeight="SemiBold" Text="{DynamicResource Update700Title3}" Foreground="White"/><LineBreak/>
                                <Run Text="{DynamicResource Update700Desc3}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bullet 4 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="ArrowSync24" Foreground="#E8611A" Margin="0,2,10,0" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="#D0D0D0" TextWrapping="Wrap" Width="350">
                                <Run FontWeight="SemiBold" Text="{DynamicResource Update700Title4}" Foreground="White"/><LineBreak/>
                                <Run Text="{DynamicResource Update700Desc4}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Margin="22,0,22,10">
                <CheckBox x:Name="ChkDontShowAgain" Content="{DynamicResource Update700DontShowAgain}" IsChecked="False" Margin="0,0,0,15" Foreground="#A0A0A0" Style="{StaticResource DotCheckBox}"/>

                <ui:Button Content="{DynamicResource GenericClose}" Width="150" HorizontalAlignment="Right" Click="BtnClose_Click" Appearance="Primary" Height="36" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
