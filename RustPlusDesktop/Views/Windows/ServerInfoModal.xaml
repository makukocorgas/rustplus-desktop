<Window x:Class="RustPlusDesk.Views.ServerInfoModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource ServerInformation}" 
        Width="500" Height="580"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Grid>
        <!-- Card Container with Shadow -->
        <Border Margin="10"
                Background="#CC16191E"
                BorderThickness="0"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="0" />
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Row 0: Banner Image -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1: Content or Loading -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Banner Header -->
                <Grid Grid.Row="0">
                    <Border CornerRadius="11,11,0,0" ClipToBounds="True" Background="#2A2F35" Height="150">
                        <Grid>
                            <!-- Banner Image -->
                            <Image x:Name="ImgBanner" 
                                   Stretch="UniformToFill" 
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed"/>
                            
                            <!-- Banner Gradient Overlay to make text readable and look premium -->
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#99000000" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="0.5"/>
                                        <GradientStop Color="#B216191E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Close Button Overlay on Banner -->
                    <Button Click="BtnClose_Click"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="15"
                            Width="32" Height="32"
                            Background="#66000000"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            Style="{StaticResource IconButton}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="16"/>
                            </Style>
                        </Button.Resources>
                        <ui:SymbolIcon Symbol="Dismiss16" Filled="False" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Loading Panel -->
                <Grid x:Name="PnlLoading" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:ProgressRing Width="36" Height="36" IsIndeterminate="True" Margin="0,0,0,12" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Loading server details..." Foreground="{DynamicResource TextSubtle}" FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Content Area -->
                <Grid x:Name="PnlContent" Grid.Row="1" Margin="20,15,20,20">
                    <Grid.RowDefinitions>
                        <!-- Row 0: Server Name -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 1: IP Address -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Stats Cards -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 3: Description -->
                        <RowDefinition Height="*"/>
                        <!-- Row 4: Buttons -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Server Name -->
                    <TextBlock x:Name="TxtName" 
                               Grid.Row="0"
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>

                    <!-- Address & Copy Button -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock x:Name="TxtAddress" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSubtle}" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <ui:Button Appearance="Secondary"
                                   Padding="6,3"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Click="BtnCopyAddress_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy20" Margin="0,0,4,0" FontSize="12"/>
                                <TextBlock Text="Copy IP"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <!-- Stats Cards -->
                    <Grid Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Players Card -->
                        <Border Grid.Column="0" Margin="0,0,6,0" Background="#0FFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="People24" Filled="True" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                <TextBlock Text="Players" FontSize="11" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtPlayers" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Queue Card -->
                        <Border Grid.Column="1" Margin="3,0,3,0" Background="#0FFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Clock24" Filled="True" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                <TextBlock Text="Queue" FontSize="11" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtQueue" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Wipe Card -->
                        <Border Grid.Column="2" Margin="6,0,0,0" Background="#0FFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="CalendarClock24" Filled="True" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                <TextBlock Text="Wipe Cycle" FontSize="11" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtWipe" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Description Area -->
                    <Grid Grid.Row="3" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" 
                                   Text="{DynamicResource Description}" 
                                   FontSize="12" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource Accent}" 
                                   Margin="0,0,0,6"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtDescription" 
                                       FontSize="13" 
                                       LineHeight="19"
                                       TextWrapping="Wrap" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       Opacity="0.9"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- Buttons at Bottom -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Website Button on Left -->
                        <ui:Button x:Name="BtnWebsite"
                                   Grid.Column="0"
                                   HorizontalAlignment="Left"
                                   Appearance="Secondary"
                                   Cursor="Hand"
                                   Click="BtnWebsite_Click"
                                   Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Globe24" Margin="0,0,6,0"/>
                                <TextBlock Text="Visit Website"/>
                            </StackPanel>
                        </ui:Button>

                        <!-- Close Button on Right -->
                        <ui:Button Grid.Column="1"
                                   Content="Close" 
                                   Appearance="Primary" 
                                   Width="100"
                                   Cursor="Hand"
                                   Click="BtnClose_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
