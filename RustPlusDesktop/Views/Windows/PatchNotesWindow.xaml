<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:RustPlusDesk.Views"
        Title="{DynamicResource PatchNotes}"
        Width="720" Height="620"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="{DynamicResource Radius}" Padding="14" Margin="8">
        <Grid>
            <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource PatchNotesHeader}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <!-- UPDATE VERSION NUMBER HERE -->
                        <TextBlock Text="{Binding CurrentVersionFormatted, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource Accent}" FontSize="11" Margin="0,0,0,4"/>
                    </StackPanel>

                    <Button x:Name="BtnTranslate" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="12,4" Click="BtnTranslate_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Translate24" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource TranslateViaGoogle}" VerticalAlignment="Center" x:Name="TxtTranslate"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="PatchNotesContent" Margin="0,0,0,12">
                    <!-- ============================================== -->
                    <!-- NEW v7.1.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v7.1.0 | Resource Heatmaps Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Resource Heatmaps (2D &amp; 3D):</Run>
                                Added fully procedural heatmaps for all resources, animals, and loot directly to the 2D and 3D maps! Visualize exactly where to find the best spots for farming.
                            </TextBlock>

                            <!-- v7.1.0 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/heatmap.png" Description="New procedural 2D Resource Heatmaps"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/heatmap-3D.png" Description="Fully integrated 3D Resource Heatmaps on the terrain"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>
                    <!-- ============================================== -->
                    <!-- OLD v7.0.2 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v7.0.2 | Hotfixes &amp; Improvements" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold" Foreground="{DynamicResource Accent}">&#x2022; Write Protection Fix:</Run>
                                Fixed a write protection issue for 3D Maps by moving the LocalBuild cache to the %APPDATA% directory instead of the application installation folder.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Enhanced !heli Command:</Run>
                                Added dynamic grid coordinate information to the !heli chat command responses.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; MapParser Stability:</Run>
                                Fixed MapParser freezing and being stuck on "Preparing..." due to output buffer overflow issues.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Cloud Domain Migration:</Run>
                                Merged the Cloud service to the new dedicated domain: www.rustplusdesktop.cloud.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Email Verification &amp; Password Reset:</Run>
                                Added in-app password reset options and fixed issues with account verification emails. We are now using our new official email: mail@rustplusdesktop.cloud.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Seamless 3D Map Setup:</Run>
                                Bundled the .NET 8 Runtime directly into MapParser.exe. It now works perfectly out-of-the-box on all PCs without requiring manual framework installations!
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; 3D Map Visuals:</Run>
                                Added new and improved ground textures for the 3D Maps.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Storage Optimization:</Run>
                                Added automatic cleanup of temporary MapParser logs and cache files upon successful 3D map extraction to save disk space.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- ============================================== -->
                    <!-- NEW v7.0.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v7.0.0 | 3D Maps, Base Footprint Builder &amp; Enhanced 2D Maps" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold" Foreground="{DynamicResource Accent}">&#x2022; Interactive 3D Maps:</Run>
                                Explore your Rust server like never before with our fully interactive 3D Maps! Includes live player positions and death markers to help you strategize and locate loot.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Optional Map File Parsing:</Run>
                                You can now optionally read your local `.map` files (safely, as read-only) by clicking the 3D Map button to extract precise in-game details. This brings exact Building Blocked Zones, Caves, Icebergs, and more directly to both your 3D and 2D maps! And don't worry, the 3D map unloads completely from RAM when closed to save resources.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; 3D Base Footprint Builder:</Run>
                                Planning a new base? Use the new Footprint Builder in the 3D map to preview exactly how your base will fit. Test if it fits between No-Build Zones, check slope steepness, or verify water depth before you build in-game.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Refined Logic Engine:</Run>
                                Our Logic Engine has been further refined for better performance and stability when constructing custom automation rules.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Enhanced Map Features:</Run>
                                In-game Team Markers are now natively displayed on the 2D map. Plus, we've added beautiful custom icons for all Smart Devices!
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Recycling Calculator:</Run>
                                Recycling Calculator for your Components and more. See the difference between safe-zone and regular recycling right away.
                            </TextBlock>

                            <!-- v7.0.0 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/Live-Following-3D.png" Description="Live player following on the interactive 3D map"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/No-Build-Zones-3D.png" Description="Exact Building Blocked Zones visualized on the 3D map"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/3D-Base-Footprint.png" Description="Checking base placement using the new 3D Base Footprint Builder"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/Ingame-Waypoints-on-map.png" Description="In-game Team Waypoints seamlessly synced to your 2D map"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/Logic-Engine.png" Description="Refined Logic Engine for advanced automation rules"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/Recycling-Calculator.png" Description="Recycling Calculator to plan your scrap runs"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/7.0/custom-icons-smart.png" Description="Brand new custom icons for Smart Devices"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>
                    <!-- ============================================== -->
                    <!-- NEW v6.3.1 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.3.1 | Overlay Subscriptions, Bandwidth &amp; Base Screenshot Fix" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold" Foreground="{DynamicResource Accent}">&#x2022; Smart Logic Engine (Beta):</Run>
                                Automate your gameplay with our brand-new Logic Engine! Construct rules using an intuitive IFTTT-style builder triggered by Smart Alarms, Smart Switches, or custom Chat Commands (which automatically sync to your Chat Settings). All subsequent steps in a rule function as logical gates: the rule execution will only proceed if the condition (like checking device availability/state) is met. This lets you use unpowered Smart Switches as simple logic inputs! Future updates will introduce cloud sharing of rules and more triggers.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Teammate Overlay Subscriptions &amp; left Dock:</Run>
                                Added a new Subscription Dock on the left side of the map to visually manage active teammate overlay subscriptions. Supports pulsing green glow indicators, quick refresh on avatar click, hover actions to unsubscribe, and a pencil button to toggle drawing mode.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Adaptive Polling &amp; Egress Optimization:</Run>
                                Massive bandwidth and server traffic reduction! Replaced static 3s polling with an intelligent back-off strategy (3s/10s/30s/60s based on tier and active changes). Pauses polling if teammates go offline. Automatically pauses Free user subscriptions after 1 hour of inactivity to save server egress.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Base Overlay Screenshot Indicators:</Run>
                                Small indicators have been added to bases on the map overlay that have screenshots attached, allowing you to easily identify bases with uploaded visual references.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Teammate Base Screenshot Fix:</Run>
                                Resolved a permission issue that prevented team members from viewing screenshots uploaded to bases by their teammates.
                            </TextBlock>

                            <!-- v6.3.1 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.3.1/LogicEngine-Button_and_subscriber_dock.png" Description="Logic Engine entry button in the device list &amp; teammate subscription overlay dock on the map"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.3.1/Logic-Engine.png" Description="Logic Engine builder showing a custom rule triggered by a team chat command"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v6.3.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.3.0 | Remote Camera Controls, WPF Device List &amp; Discord Resilience" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Custom Smart Device Icons:</Run>
                                Assign custom icons to your smart devices in the Device List for better overview and easier management at a glance.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Flexible Window Layout &amp; Resolution Support:</Run>
                                Reduced the minimum window and map width constraints, allowing players on lower display resolutions or stretched aspect ratios (like 4:3) to comfortably scale and fit the application on their screens.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Premium WPF Device List Layout:</Run>
                                Overhauled the smart device dashboard with a gorgeous, modernized WPF-styled list design, providing a cleaner grid view and faster switch control access.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Remote Camera &amp; Turret Controls:</Run>
                                Complete remote control integration for Auto-Turrets and PTZ cameras! Supports mouse-drag steering, continuous button actions (firing, reloading, jumping, ducking), and smooth frame streaming.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; AFK Status &amp; Indicators:</Run>
                                Easily identify inactive players! Added AFK status indicators to player cards, integrated with active command indicators.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Chat Customization &amp; Command Delays:</Run>
                                Full customization overlays for Team Chat styles alongside customizable command execution delays to prevent spam rate-limits.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Hardened Discord Polling Connection:</Run>
                                Resolved a database keep-alive issue. Optimizations to the polling database connection now prevent the Discord bot integration from disconnecting after two hours of inactivity.
                            </TextBlock>

                            <!-- v6.3.0 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/window-size.png" Description="Enhanced Flexible Window Resizing for Stretched Resolutions"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/devices-icons.png" Description="Customizable Icons for Smart Devices in the Device List"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/camera_move.png" Description="Remote Camera &amp; Turret Mouse-Steering with Live Controls"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/WPF_devicelist.png" Description="Modernized WPF-styled Device List Dashboard Layout"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/afk.png" Description="AFK Status Indicators on Player Cards"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/Chat-Command-Customization.png" Description="Chat Customization Settings Panel Overlay"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/Chat-Command-Delay.png" Description="Chat Command Delay Settings Slider"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v6.2.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.2.0 | Crosshair Memory, Hardened Setup &amp; Polling Optimizations" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Smart Crosshair Memory:</Run>
                                The custom crosshair overlay now remembers your last selected style! Toggling the crosshair off and on again will automatically restore your design instead of reverting to the standard format.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Bulletproof Setup &amp; Pairing:</Run>
                                Clicking the "Login &amp; Pair Account" button on the setup screen now instantly clears any running, blocked, or expired background processes and local configs to guarantee a clean, instant browser login flow.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Clean Logs &amp; Quiet Polling:</Run>
                                Massive under-the-hood performance updates to suppress redundant log entries and console spam, delivering a cleaner logger feed and a smoother desktop application experience.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Solo Bandwidth Optimizer:</Run>
                                When playing alone in a team or when teammates are offline, the client now dynamically suspends status polling database calls to save immense amounts of server bandwidth and RAM.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Cloud Device Sync Fix:</Run>
                                Fixed a cache synchronization bug. Deleting a smart device from the UI now immediately registers the deletion and purges the device from the cloud overlay database permanently.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Discord Map Integrations:</Run>
                                Added direct map exports to Discord Chat-Alerts using /map and /mapfull commands, alongside enhanced hotkey mapping.
                            </TextBlock>
                            
                            <!-- v6.2.0 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/MapFetchDiscord.png" Description="Discord Map Fetch and Send from App"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/death-notifications.png" Description="Offline Death Settings and Player Log History"/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/6.0 Cloud Patch/death-snackbar.png" Description="Offline Death Snackbar Popup Alert with Stop Trigger"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v6.0.2 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.0.2 | Hotfix Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Event Notifications Fixed:</Run>
                                All event notifications (e.g. Deep Sea, Cargo Ship, Patrol Heli) now correctly show up in the Event Channel instead of just Oil Rig and Timers.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Player Direction Indicator:</Run>
                                Added a direction indicator for the movement direction of players. This feature can be toggled in the Team tab.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; UI Improvements:</Run>
                                Improved the layout of the UI timer section.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Team Markers Settings:</Run>
                                Added a new Team Marker section to the main application settings.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Shop Alerts Fixed:</Run>
                                Persistent Shop Alerts are now correctly loaded upon application start.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="Bold">&#x2022; Deleted Device Hotkeys Fixed:</Run>
                                Hotkeys associated with deleted devices are now visible in the Hotkeys menu and are automatically removed when deleting devices.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v6.0.1 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.0.1 | Discord, Timer &amp; Raid Alert Hotfix" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" Foreground="{DynamicResource Accent}"/>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Discord TTS Support:</Run>
                                Webhook notifications can now use text-to-speech.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Custom Timer Rework:</Run>
                                Added customizable 1-minute countdown and time-up alarms, each individually configurable and toggleable per timer.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Separate Shop Alert Channel:</Run>
                                Advanced Discord Bot users can now route shop alerts to their own channel.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Advanced Bot Database Fix:</Run>
                                Saving an empty channel now correctly removes the previous database entry.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Soft Connect Raid Alerts:</Run>
                                FCM Raid Alerts can now be delivered to Discord while the client is connected using Soft Connect.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                <Run FontWeight="Bold">&#x2022; Multi-Device !switch Commands:</Run>
                                The same chat command can now be assigned to multiple switches and trigger them together.
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="Bold">&#x2022; Safer Discord Webhook Setup:</Run>
                                Improved the Chat Alerts integration to help prevent accidentally closing the setup window.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- NEW v6.0.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v6.0.0 | The Cloud &amp; Intelligence Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            
                            <TextBlock Text="&#x2022; Cloud Features &amp; Account Integration" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Rust+ Desktop now offers a full Cloud Backend! Create an account via Email or Discord to access powerful features like Device Sync, Map Overlay Sharing with Base Screenshots, and the new Cloud Portal.
                            </TextBlock>
                            
                            <ui:Button Content="{DynamicResource CompareCloudFeatures}" Appearance="Secondary" Icon="Info24" Margin="0,5,0,15" HorizontalAlignment="Left" Click="BtnCompareCloud_Click"/>

                            <TextBlock Text="&#x2022; Advanced Discord Integration &amp; Bots" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Basic alerts go straight to Discord. Supporter Tier users get their own bidirectional Discord Bot with custom command permissions, raid alerts, and event queries directly from their Discord servers.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Chat Master System" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                                Supporter Tier users can become "Chat Master" to silence duplicate chat commands and alerts for the entire team, intelligently handing off master status when closing the app.
                            </TextBlock>
                            
                            <TextBlock Text="&#x2022; Custom Timers &amp; Shop Overhaul" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                <Run FontWeight="Bold">Custom Timers:</Run> Create timers via UI or !timer chat command with 60, 30, 10, 3 minute chat alerts.
                                <LineBreak/>
                                <Run FontWeight="Bold">Shop Overhaul:</Run> Filter by price/resource, Profit Trade and Buy X layouts.
                                <LineBreak/>
                                <Run FontWeight="Bold">Map Tweaks:</Run> Customizable local death markers. Minimap continues tracking when minimized.
                            </TextBlock>

