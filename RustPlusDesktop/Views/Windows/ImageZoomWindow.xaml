<Window x:Class="RustPlusDesk.Views.ImageZoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Image Zoom View"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Grid Background="#F207090C">
        <!-- Main Zoom & Pan Area -->
        <Grid x:Name="ZoomContainer" 
              ClipToBounds="True" 
              Background="Transparent" 
              MouseWheel="ZoomContainer_MouseWheel" 
              MouseLeftButtonDown="ZoomContainer_MouseLeftButtonDown" 
              MouseLeftButtonUp="ZoomContainer_MouseLeftButtonUp" 
              MouseMove="ZoomContainer_MouseMove"
              Cursor="SizeAll">
            
            <!-- Zoomed Image -->
            <Image x:Name="ZoomedImage" 
                   Stretch="Uniform" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ImgScale"/>
                        <TranslateTransform x:Name="ImgTranslate"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <!-- Instructions Overlay -->
        <Grid IsHitTestVisible="False" Margin="24">
            <Border HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Background="#B0000000" 
                    Padding="16,8" 
                    CornerRadius="20">
                <TextBlock Text="Scroll to Zoom • Drag to Pan • Click or ESC to Close • Double-Click to Reset" 
                           Foreground="#E0E0E0" 
                           FontSize="12" 
                           FontWeight="Medium"/>
            </Border>
        </Grid>
        
        <!-- Premium Close Button in Top-Right -->
        <Button HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="24" 
                Width="44" 
                Height="44" 
                Background="#30FFFFFF" 
                BorderThickness="0" 
                Foreground="White" 
                Cursor="Hand" 
                Click="Close_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="22">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <ui:SymbolIcon Symbol="Dismiss24" FontSize="20"/>
        </Button>
    </Grid>
</Window>
