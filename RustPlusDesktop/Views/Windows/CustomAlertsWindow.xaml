<Window x:Class="RustPlusDesk.Views.Windows.CustomAlertsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource CustomAlertsTitle}"
        Width="700" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Grid>
        <!-- Card Container with Shadow -->
        <Border Margin="15"
                Background="#16191E"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="Black" Opacity="0.65" ShadowDepth="0" />
            </Border.Effect>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- List of Alerts -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header area with DragMove support -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource CustomAlertsHeader}" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="{DynamicResource CustomAlertsDesc}" 
                                   Foreground="#88FFFFFF" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- Close button in Header -->
                    <ui:Button Grid.Column="1" Click="BtnClose_Click" Appearance="Transparent" Padding="6" VerticalAlignment="Top" ToolTip="{DynamicResource Close}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Dismiss24" Foreground="#88FFFFFF"/>
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>

                <!-- Scrollable List of Alert Templates -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-8,16" Padding="0,0,8,0">
                    <ItemsControl x:Name="AlertsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1D24"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Text Fields and Variable details -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="White" />
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#88FFFFFF" Margin="0,2,0,8" TextWrapping="Wrap"/>
                                            
                                            <ui:TextBox Text="{Binding CurrentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        Background="#11FFFFFF" 
                                                        Foreground="White" 
                                                        BorderBrush="#25FFFFFF" 
                                                        BorderThickness="1" 
                                                        Padding="8,6" 
                                                        FontSize="12" 
                                                        TextWrapping="Wrap" 
                                                        AcceptsReturn="False"/>

                                            <TextBlock Text="{Binding Variables}" FontSize="10" Foreground="#55FFFFFF" Margin="2,6,0,0" />
                                        </StackPanel>

                                        <!-- Actions Row -->
                                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                            <!-- Save Button -->
                                            <ui:Button Click="BtnSave_Click" Appearance="Primary" Padding="8" Margin="0,0,0,8" ToolTip="{DynamicResource Save}">
                                                <ui:Button.Icon>
                                                    <ui:SymbolIcon Symbol="Save24" />
                                                </ui:Button.Icon>
                                            </ui:Button>

                                            <!-- Reset Button -->
                                            <ui:Button Click="BtnReset_Click" Appearance="Secondary" Padding="8" ToolTip="{DynamicResource Reset}">
                                                <ui:Button.Icon>
                                                    <ui:SymbolIcon Symbol="ArrowUndo24" />
                                                </ui:Button.Icon>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <ui:Button Content="{DynamicResource Close}" Width="100" Height="34" Click="BtnClose_Click" Appearance="Secondary" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
