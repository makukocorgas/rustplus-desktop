<ui:FluentWindow x:Class="RustPlusDesk.Views.DeviceImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        Title="{DynamicResource ImportDevicesTitle}"
        Width="760"
        Height="580"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowBackdropType="Mica"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowsTransparency="False"
        ShowInTaskbar="False">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Border Grid.Row="0"
                Background="#0F1013"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <ui:TitleBar Title="{DynamicResource ImportDevicesTitle}"
                         Background="Transparent"
                         Foreground="White">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/rustplus-desktop-icon.ico" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="1"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius}"
                Padding="16"
                Margin="8">

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Probing Progress Panel -->
                    <RowDefinition Height="Auto" />
                    <!-- Search & List -->
                    <RowDefinition Height="*" />
                    <!-- Footer Actions -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header Section -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource ImportDevicesHeader}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>

                    <TextBlock Text="{Binding SourceDescription}"
                               Foreground="{DynamicResource Accent}"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="0,2,0,4"/>

                    <TextBlock Text="{DynamicResource ImportDevicesSelectPrompt}"
                               Foreground="{DynamicResource TextSubtle}"
                               FontSize="13"/>
                </StackPanel>

                <!-- Probing Progress Bar (Visible only when probing) -->
                <Border Grid.Row="1" 
                        Background="{DynamicResource SurfaceAlt}" 
                        BorderBrush="{DynamicResource CardBorder}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,12"
                        Visibility="{Binding IsProbing, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding ProbingStatus}" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                                   
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding ProbingProgressText}" 
                                   Foreground="{DynamicResource TextSubtle}" 
                                   VerticalAlignment="Center"
                                   FontSize="11"/>

                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" 
                                     Height="6" 
                                     Margin="0,8,0,0" 
                                     Minimum="0" 
                                     Maximum="{Binding ProbingMax}" 
                                     Value="{Binding ProbingProgress}" 
                                     Foreground="{DynamicResource Accent}"/>
                    </Grid>
                </Border>

                <!-- Search + Device List -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Search Bar -->
                        <RowDefinition Height="Auto" /> <!-- Summary Info -->
                        <RowDefinition Height="*" />    <!-- List -->
                    </Grid.RowDefinitions>

                    <!-- Search box -->
                    <ui:TextBox Grid.Row="0"
                                PlaceholderText="Search devices by name, type, owner, ID..."
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Icon="{ui:SymbolIcon Symbol=Search24}"
                                Margin="0,0,0,8"
                                ClearButtonEnabled="True" />

                    <!-- Summary Text -->
                    <TextBlock Grid.Row="1" 
                               Text="{Binding SummaryText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSubtle}"
                               Margin="0,0,0,8" />

                    <!-- Scrollable Device list and Empty State -->
                    <Grid Grid.Row="2">
                        <!-- Scrollable Device list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      ScrollViewer.PanningMode="VerticalOnly">

                            <ItemsControl ItemsSource="{Binding Devices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Margin="0,0,8,8" Padding="12">
                                            <ui:Card.Style>
                                                <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AlreadyPresent}" Value="True">
                                                            <Setter Property="Opacity" Value="0.55"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Card.Style>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Selection checkbox -->
                                                <CheckBox Grid.Column="0" 
                                                          Style="{StaticResource DotCheckBox}"
                                                          IsChecked="{Binding IsSelected}"
                                                          IsEnabled="{Binding IsSelectable}"                                    
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0" />

                                                <!-- Device icon -->
                                                <Border Grid.Column="1"
                                                        Width="36"
                                                        Height="36"
                                                        Background="#14FFFFFF"
                                                        CornerRadius="6"
                                                        Padding="6"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <Image Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="/Assets/icons/smartswitch.png" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="SmartAlarm">
                                                                        <Setter Property="Source" Value="/Assets/icons/smartalarm.png" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="SmartSwitch">
                                                                        <Setter Property="Source" Value="/Assets/icons/smartswitch.png" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="StorageMonitor">
                                                                        <Setter Property="Source" Value="/Assets/icons/storagemonitor.png" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Border>

                                                <!-- Device main info -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13.5">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ExistsState}" Value="missing">
                                                                        <Setter Property="Foreground" Value="Tomato" />
                                                                        <Setter Property="FontStyle" Value="Italic" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <ui:SymbolIcon Symbol="Person20" FontSize="12" Foreground="{DynamicResource TextSubtle}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Tagline}"
                                                                   Foreground="{DynamicResource TextSubtle}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Status Badge -->
                                                <Border Grid.Column="3" 
                                                        VerticalAlignment="Center" 
                                                        HorizontalAlignment="Right"
                                                        CornerRadius="6"
                                                        Padding="8,4"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#0FFFFFFF"/>
                                                            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ExistsState}" Value="ok">
                                                                    <Setter Property="Background" Value="#1A4CAF50"/>
                                                                    <Setter Property="BorderBrush" Value="#334CAF50"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExistsState}" Value="missing">
                                                                    <Setter Property="Background" Value="#1AF44336"/>
                                                                    <Setter Property="BorderBrush" Value="#33F44336"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExistsState}" Value="local">
                                                                    <Setter Property="Background" Value="#1A2196F3"/>
                                                                    <Setter Property="BorderBrush" Value="#332196F3"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Margin="0,0,4,0" FontSize="13" VerticalAlignment="Center">
                                                            <ui:SymbolIcon.Style>
                                                                <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Symbol" Value="QuestionCircle20"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="ok">
                                                                            <Setter Property="Symbol" Value="CheckmarkCircle20"/>
                                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="missing">
                                                                            <Setter Property="Symbol" Value="DismissCircle20"/>
                                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="local">
                                                                            <Setter Property="Symbol" Value="Info20"/>
                                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="err">
                                                                            <Setter Property="Symbol" Value="Warning20"/>
                                                                            <Setter Property="Foreground" Value="#FFA500"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:SymbolIcon.Style>
                                                        </ui:SymbolIcon>
                                                        
                                                        <TextBlock Text="{Binding ExtraInfo}"
                                                                   FontSize="11"
                                                                   FontWeight="Medium"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="ok">
                                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="missing">
                                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="local">
                                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ExistsState}" Value="err">
                                                                            <Setter Property="Foreground" Value="#FFA500"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty State -->
                        <TextBlock Text="No devices match your search."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSubtle}"
                                   FontSize="14"
                                   FontStyle="Italic"
                                   Visibility="{Binding NoDevicesVisible, Converter={StaticResource BoolToVisConverter}}" />
                    </Grid>
                </Grid>

                <!-- Footer command bar -->
                <Border Grid.Row="3"
                        Padding="0,12,0,0"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left actions: Selection helpers + Probing -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Content="{DynamicResource SelectAll}"
                                       Icon="{ui:SymbolIcon Symbol=CheckmarkSquare24}"
                                       Click="BtnSelectAll_Click"
                                       IsEnabled="{Binding IsNotProbing}"/>
                            
                            <ui:Button Content="{DynamicResource DeselectAll}"
                                       Icon="{ui:SymbolIcon Symbol=Square24}"
                                       Margin="8,0,0,0"
                                       Click="BtnDeselectAll_Click"
                                       IsEnabled="{Binding IsNotProbing}"/>
                                       
                            <ui:Button Content="{DynamicResource CheckDeviceStatus}"
                                       Icon="{ui:SymbolIcon Symbol=HeartPulse24}"
                                       Margin="16,0,0,0"
                                       Click="BtnCheckStatus_Click"
                                       IsEnabled="{Binding IsNotProbing}"
                                       Appearance="Secondary"/>
                        </StackPanel>

                        <!-- Right actions: Cancel + Import -->
                        <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                            <ui:Button Content="{DynamicResource Cancel}"
                                       Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                       IsCancel="True"
                                       Click="BtnCancel_Click" />
                                       
                            <ui:Button Content="{DynamicResource ImportSelected}"
                                       Icon="{ui:SymbolIcon Symbol=ArrowImport24}"
                                       IsDefault="True"
                                       Click="BtnImport_Click"
                                       Margin="8,0,0,0"
                                       Appearance="Primary"
                                       IsEnabled="{Binding CanImport}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
