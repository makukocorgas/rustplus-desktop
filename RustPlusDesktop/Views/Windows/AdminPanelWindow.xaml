<Window x:Class="RustPlusDesk.Views.Windows.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Admin Panel"
        Width="1000" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#0F1215"
        Foreground="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <ui:SymbolIcon Symbol="Shield24" Foreground="#FF3B30" FontSize="24" Margin="0,0,10,0"/>
            <TextBlock Text="Admin Panel - User Overview" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid x:Name="UsersGrid" 
                  Grid.Row="1" 
                  MouseDoubleClick="UsersGrid_MouseDoubleClick"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  Background="#1A1D24" 
                  Foreground="White"
                  RowBackground="#1A1D24"
                  AlternatingRowBackground="#22262F"
                  BorderBrush="#333"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Steam ID" Binding="{Binding SteamId}" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="Discord Name" Binding="{Binding DiscordName}" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="Tier" Binding="{Binding SubscriptionTier}" Width="120" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="Sync OK" Binding="{Binding SyncAccepted}" Width="80" IsReadOnly="True" />
                <DataGridTextColumn Header="Last Active" Binding="{Binding LastActiveDisplay}" Width="160" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline, Mode=OneWay}" Width="70" IsReadOnly="True" />
                <DataGridTextColumn Header="Server" Binding="{Binding CurrentServerName}" Width="180" IsReadOnly="True" />
                <DataGridTextColumn Header="Team" Binding="{Binding TeamMemberCount}" Width="60" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="Manual Premium" Binding="{Binding IsManualSupporter, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                <DataGridTextColumn Header="Manual Since" Binding="{Binding ManualPremiumAtDisplay}" Width="160" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

