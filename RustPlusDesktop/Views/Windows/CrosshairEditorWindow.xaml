<Window x:Class="RustPlusDesk.CrosshairEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        Title="{DynamicResource DrawCrosshair}" Height="650" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#181A1E" Foreground="White"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Styles for toggle buttons to look like standard buttons but checked state -->
        <Style x:Key="ToolButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#2A2D35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                BorderBrush="#404040" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#4A90E2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderBrush="#181A1E" BorderThickness="2">
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <RadioButton Content="{DynamicResource Pixel}" Style="{StaticResource ToolButtonStyle}" IsChecked="True" Tag="Pixel" Checked="Tool_Checked"/>
            <RadioButton Content="{DynamicResource Pen}" Style="{StaticResource ToolButtonStyle}" Tag="Pen" Checked="Tool_Checked"/>
            <RadioButton Content="{DynamicResource Line}" Style="{StaticResource ToolButtonStyle}" Tag="Line" Checked="Tool_Checked"/>
            <RadioButton Content="{DynamicResource Square}" Style="{StaticResource ToolButtonStyle}" Tag="Rectangle" Checked="Tool_Checked"/>
            <RadioButton Content="{DynamicResource Circle}" Style="{StaticResource ToolButtonStyle}" Tag="Ellipse" Checked="Tool_Checked"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="White" Tag="White" IsChecked="True" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Lime" Tag="Lime" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Yellow" Tag="Yellow" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Magenta" Tag="Magenta" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Cyan" Tag="Cyan" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Red" Tag="Red" Checked="Color_Checked"/>
            <RadioButton Style="{StaticResource ColorButtonStyle}" Background="Black" Tag="Black" Checked="Color_Checked"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource Thickness}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="ThicknessSlider" Width="60" Minimum="1" Maximum="10" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ElementName=ThicknessSlider, Path=Value}" VerticalAlignment="Center" Margin="10,0,0,0" Width="20"/>
            
            <TextBlock Text="{DynamicResource Opacity}" VerticalAlignment="Center" Margin="10,0,10,0"/>
            <Slider x:Name="OpacitySlider" Width="60" Minimum="0.1" Maximum="1.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="10,0,0,0" Width="25"/>
            
            <Button Content="{DynamicResource UploadPNG}" Margin="10,0,0,0" Padding="10,2" Background="#4A90E2" Foreground="White" BorderThickness="0" Click="BtnUpload_Click"/>
            <Button Content="{DynamicResource Clear}" Margin="10,0,0,0" Padding="10,2" Background="#D32F2F" Foreground="White" BorderThickness="0" Click="BtnClear_Click"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#333333" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="512" Height="512" BorderBrush="#555" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <!-- Grid background -->
                <Grid IsHitTestVisible="False">
                    <Grid.Background>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#22FFFFFF" Thickness="0.5"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,8,8"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>
                </Grid>
                
                <!-- Center guidelines -->
                <Line X1="0" Y1="256" X2="512" Y2="256" Stroke="#555" StrokeThickness="1" StrokeDashArray="2 2" IsHitTestVisible="False"/>
                <Line X1="256" Y1="0" X2="256" Y2="512" Stroke="#555" StrokeThickness="1" StrokeDashArray="2 2" IsHitTestVisible="False"/>
                
                <!-- This grid is what we render to PNG -->
                <Grid x:Name="RenderGrid">
                    <Image x:Name="BackgroundImage" Width="512" Height="512" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <Canvas x:Name="DrawCanvas" Width="512" Height="512" Background="Transparent"
                            MouseDown="DrawCanvas_MouseDown" MouseMove="DrawCanvas_MouseMove" MouseUp="DrawCanvas_MouseUp"/>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="{DynamicResource Cancel}" Margin="0,0,10,0" Padding="15,5" Background="#444" Foreground="White" BorderThickness="0" Click="BtnCancel_Click"/>
            <Button Content="{DynamicResource Save}" Padding="15,5" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
