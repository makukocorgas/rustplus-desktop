<Window x:Class="RustPlusDesk.Views.Windows.ChangeDeviceIconDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Change Device Icon" 
        Height="520" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Grid>
        <!-- Card Container with Shadow -->
        <Border Width="380" Height="480"
                Background="#16191E"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.65" ShadowDepth="0" />
            </Border.Effect>
            
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title & Subtitle -->
                    <RowDefinition Height="Auto"/> <!-- Search input -->
                    <RowDefinition Height="*"/>    <!-- List box -->
                    <RowDefinition Height="Auto"/> <!-- Reset button -->
                    <RowDefinition Height="Auto"/> <!-- Action buttons -->
                </Grid.RowDefinitions>
                
                 <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="TxtSubtitle" FontSize="11" Foreground="#88FFFFFF" Margin="0,2,0,0"/>
                </StackPanel>
                
                <!-- Search Box -->
                <ui:TextBox x:Name="TxtSearch" 
                            Grid.Row="1" 
                            PlaceholderText="Search icons (e.g. turret, switch)..." 
                            Icon="Search24"
                            Background="#1A1D24"
                            BorderBrush="#25FFFFFF"
                            Foreground="White"
                            FontSize="12"
                            Margin="0,0,0,10"
                            TextChanged="TxtSearch_TextChanged"
                            PreviewKeyDown="TxtSearch_PreviewKeyDown"/>
                
                <!-- List Box of Matches -->
                <ListBox x:Name="LstItems" 
                         Grid.Row="2" 
                         Background="#11FFFFFF"
                         BorderBrush="#1AFFFFFF"
                         BorderThickness="1"
                         Margin="0,0,0,10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="LstItems_MouseDoubleClick"
                         SelectionChanged="LstItems_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="1,1" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1EFFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3360CDFF" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF60CDFF" />
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Background="Transparent" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0" Source="{Binding Icon}" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock Grid.Column="1" Text="{Binding Display}" Foreground="White" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Reset Button -->
                <ui:Button x:Name="BtnReset" 
                           Grid.Row="3" 
                           Content="Reset to Default Icon" 
                           Appearance="Secondary"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,16"
                           Click="BtnReset_Click"/>
                
                <!-- Action Buttons -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button x:Name="BtnCancel" Content="Cancel" Appearance="Secondary" Margin="0,0,8,0" Width="80" Click="BtnCancel_Click"/>
                        <ui:Button x:Name="BtnSave" Content="Save" Appearance="Primary" Width="80" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
