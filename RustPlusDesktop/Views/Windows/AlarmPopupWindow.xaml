<Window x:Class="RustPlusDesk.Views.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        Title="{DynamicResource Alarms}" Width="550" Height="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#121417"/>
        <SolidColorBrush x:Key="Surface" Color="#1C1F24"/>
        <SolidColorBrush x:Key="SurfaceAlt" Color="#23272E"/>
        <SolidColorBrush x:Key="Accent" Color="#4FC3F7"/>
        <SolidColorBrush x:Key="RustRed" Color="#CE422B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#ECEFF1"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#B0BEC5"/>
        <CornerRadius x:Key="Radius">12</CornerRadius>
    </Window.Resources>

    <Border Background="{StaticResource Surface}" 
            BorderBrush="{StaticResource RustRed}" 
            BorderThickness="2" 
            CornerRadius="{StaticResource Radius}"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="15,10" Background="{StaticResource SurfaceAlt}" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Text="{DynamicResource IncomingAlarms}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource RustRed}" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource Wipe}" Padding="12,4" Margin="0,0,8,0" Click="BtnClear_Click" 
                                Background="Transparent" Foreground="{StaticResource TextSubtle}" BorderBrush="{StaticResource TextSubtle}"/>
                        <Button Width="28" Height="28" Content="✕" FontSize="14" FontWeight="Bold" 
                                Click="BtnClose_Click" Background="Transparent" Foreground="{StaticResource TextSubtle}" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- List -->
            <ListBox x:Name="ListAlarms" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceAlt}" Margin="0,0,0,8" Padding="12" CornerRadius="8" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="pack://application:,,,/Assets/icons/smartalarm.png" Width="32" Height="32" Margin="0,0,12,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{StaticResource TextSubtle}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" FontSize="11" Foreground="{StaticResource TextSubtle}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Server}" FontSize="10" Foreground="{StaticResource Accent}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
