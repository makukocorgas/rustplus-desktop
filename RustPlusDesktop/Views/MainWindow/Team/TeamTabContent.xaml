<UserControl
    x:Class="RustPlusDesk.Views.TeamTabContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RustPlusDesk.Converters"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="Vis" />
            <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />

            <Style x:Key="TeamToggleCheckBox" TargetType="CheckBox">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentIconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="6" />
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </Grid.Resources>

        <!-- Team Members -->
        <ui:Card
            Grid.Row="0"
            Margin="12,12,12,6"
            Padding="12"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <ListBox
                x:Name="TeamList"
                Background="Transparent"
                BorderThickness="0"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding TeamMembers, RelativeSource={RelativeSource AncestorType=Window}}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Resources>
                    <ContextMenu x:Key="TeamContextMenu" Style="{StaticResource DarkContextMenu}">
                        <MenuItem Click="Team_Center_Click" Header="{DynamicResource CenterOnMap}" />
                        <MenuItem Click="Team_Follow_Click" Header="{DynamicResource FollowOnMap}" />
                        <MenuItem Click="Team_OpenProfile_Click" Header="{DynamicResource OpenSteamProfile}" />
                        <Separator />
                        <MenuItem Click="Team_Promote_Click" Header="{DynamicResource PromoteToLeader}" />
                    </ContextMenu>
                </ListBox.Resources>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Width" Value="220" />
                        <Setter Property="Margin" Value="6" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <EventSetter Event="MouseLeftButtonUp" Handler="TeamItem_MouseLeftButtonUp" />
                        <Setter Property="ContextMenu" Value="{StaticResource TeamContextMenu}" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:Card
                            Padding="10"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    IsChecked="{Binding ShowMarkers}"
                                    ToolTip="Show markers on map">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Border
                                                            x:Name="Bd"
                                                            Width="16" Height="16"
                                                            Background="#1AFFFFFF"
                                                            BorderBrush="#30FFFFFF"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            SnapsToDevicePixels="True">
                                                            <Path x:Name="CheckMark" Data="M3.5,8 L6.5,11 L12.5,4.5" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#3D4B5C" />
                                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                                                <Setter TargetName="Bd" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="4" Color="#60CDFF" Opacity="0.3" ShadowDepth="0" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <Grid
                                    Grid.Column="1"
                                    Width="44"
                                    Height="44">
                                    <Image
                                        ClipToBounds="True"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding Avatar}"
                                        Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22" />
                                        </Image.Clip>
                                    </Image>
                                    <Border
                                        Width="12"
                                        Height="12"
                                        Margin="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Background="#4CAF50"
                                        BorderBrush="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding IsOnline, Converter={StaticResource Vis}}" />
                                    <Border
                                        Width="12"
                                        Height="12"
                                        Margin="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource TextFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding IsOnline, Converter={StaticResource VisInv}}" />
                                    <ui:SymbolIcon
                                        Width="20"
                                        Height="20"
                                        Margin="-4,-4,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Foreground="Gold"
                                        Symbol="Star24"
                                        Visibility="{Binding IsLeader, Converter={StaticResource Vis}}" />
                                    <ui:SymbolIcon
                                        Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                        Symbol="Sleep24"
                                        Visibility="{Binding IsAfk, Converter={StaticResource Vis}}" />
                                </Grid>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock FontSize="14" FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="DisplayName" />
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Opacity="0.8"
                                        Text="{Binding DisplaySteamId}" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                        FontWeight="SemiBold"
                                        Text="{Binding AfkText}"
                                        Visibility="{Binding IsAfk, Converter={StaticResource Vis}}" />
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ui:Card>

        <!-- Toolbar -->
        <ui:Card
            Grid.Row="1"
            Margin="12,6,12,12"
            Padding="12"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Marker Toggles -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{DynamicResource Markers}" />

                    <CheckBox
                        x:Name="ChkProfileMarkers"
                        Margin="0,0,12,0"
                        Checked="ChkProfileMarkers_Toggled"
                        IsChecked="True"
                        Style="{StaticResource TeamToggleCheckBox}"
                        Unchecked="ChkProfileMarkers_Toggled">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="20" Height="20" Margin="0,0,6,0">
                                <Ellipse Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibility}}">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                    <Ellipse.Clip>
                                        <EllipseGeometry Center="10,10" RadiusX="10" RadiusY="10" />
                                    </Ellipse.Clip>
                                </Ellipse>
                                <ui:SymbolIcon
                                    FontSize="20"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Symbol="PersonCircle24"
                                    Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                            </Grid>
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource Profile}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </CheckBox>

                    <CheckBox
                        x:Name="ChkPlayerArrows"
                        Margin="0,0,12,0"
                        Checked="ChkPlayerArrows_Toggled"
                        IsChecked="True"
                        Style="{StaticResource TeamToggleCheckBox}"
                        Unchecked="ChkPlayerArrows_Toggled">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,6,0"
                                Foreground="LimeGreen"
                                Symbol="Navigation24"
                                Visibility="{Binding IsChecked, ElementName=ChkPlayerArrows, Converter={StaticResource BoolToVisibility}}" />
                            <ui:SymbolIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,6,0"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Symbol="Navigation24"
                                Visibility="{Binding IsChecked, ElementName=ChkPlayerArrows, Converter={StaticResource BoolToVisibilityInv}}" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource PlayerDirectionArrow}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </CheckBox>

                    <Grid x:Name="DeathMarkerToggleContainer" Background="Transparent" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox
                                x:Name="ChkDeathMarkers"
                                VerticalAlignment="Center"
                                Checked="ChkDeathMarkers_Toggled"
                                IsChecked="False"
                                Style="{StaticResource TeamToggleCheckBox}"
                                Unchecked="ChkDeathMarkers_Toggled">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="20" Height="20" Margin="0,0,6,0">
                                        <ui:SymbolIcon
                                            FontSize="20"
                                            Foreground="IndianRed"
                                            Symbol="Location24"
                                            Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}" />
                                        <ui:SymbolIcon
                                            FontSize="20"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="Location24"
                                            Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                    </Grid>
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource Death}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </CheckBox>

                            <Button
                                x:Name="BtnDeathMarkerSettings"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Click="BtnDeathMarkerSettings_Click">
                                <ui:SymbolIcon FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="Settings24" />
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource FluentIconButton}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=DeathMarkerToggleContainer}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Streamer Mode -->
                <ToggleButton
                    x:Name="BtnAbbreviateNames"
                    Grid.Column="1"
                    Width="28"
                    Height="28"
                    Margin="0,0,12,0"
                    HorizontalAlignment="Left"
                    Checked="BtnAbbreviateNames_Toggled"
                    ToolTip="{DynamicResource StreamerMode}"
                    Unchecked="BtnAbbreviateNames_Toggled">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                    <TextBlock
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                        Text="A..." />
                </ToggleButton>

                <!-- Icon Size -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{DynamicResource ScaleLabel}" />
                    <Slider
                        x:Name="SliderPlayerIconSize"
                        Width="80"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True"
                        Maximum="1.5"
                        Minimum="0.5"
                        TickFrequency="0.05"
                        Value="1.0"
                        ValueChanged="SliderPlayerIconSize_ValueChanged" />
                    <TextBlock
                        Width="36"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Value, ElementName=SliderPlayerIconSize, StringFormat={}{0:P0}}" />
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
