<UserControl
    x:Class="RustPlusDesk.Views.NotificationsTabContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:RustPlusDesk.Converters"
    xmlns:services="clr-namespace:RustPlusDesk.Services">
    
    <Grid Background="#181A1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="Vis" />
            <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />
            <conv:NotNullToBoolConverter x:Key="NotNull" />

            <Style x:Key="PillRadioButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3D4B5C" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Top Actions & Filter Bar -->
        <Border Grid.Row="0" Margin="8,8,8,4" Padding="10" Background="#FF141F2D" CornerRadius="8">
            <StackPanel>
                <!-- Row 1: Filters -->
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource NotificationsFilter}" VerticalAlignment="Center" Foreground="#8C96A8" FontSize="11" Margin="4,0,8,0" FontWeight="SemiBold"/>
                    <RadioButton x:Name="RadAll" Content="{DynamicResource NotificationsAll}" IsChecked="True" Checked="Filter_Changed" Style="{StaticResource PillRadioButton}" Margin="0,0,4,0"/>
                    <RadioButton x:Name="RadAlarms" Content="{DynamicResource NotificationsAlarms}" Checked="Filter_Changed" Style="{StaticResource PillRadioButton}" Margin="0,0,4,0"/>
                    <RadioButton x:Name="RadDeaths" Content="{DynamicResource NotificationsDeaths}" Checked="Filter_Changed" Style="{StaticResource PillRadioButton}" Margin="0,0,4,0"/>
                </WrapPanel>

                <!-- Row 2: Search + Bulk Actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBox x:Name="TxtSearch" 
                                Margin="0,0,8,0" 
                                PlaceholderText="{DynamicResource SearchNotificationsPlaceholder}" 
                                TextChanged="TxtSearch_TextChanged"
                                Icon="{ui:SymbolIcon Symbol=Search24}"
                                VerticalAlignment="Center"
                                Height="28"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Click="BtnMarkAllRead_Click" 
                                   Content="{DynamicResource MarkAllAsRead}" 
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Symbol=MailRead24}"
                                   Height="28" 
                                   FontSize="11"/>
                        <ui:Button Click="BtnClearHistory_Click" 
                                   Content="{DynamicResource ClearNotifications}" 
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Symbol=Delete24}"
                                   Height="28" 
                                   FontSize="11" 
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Notifications List -->
        <Grid Grid.Row="1" Margin="8,4,8,8">
            <!-- Empty State View -->
            <StackPanel x:Name="EmptyStatePanel" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Mail24" FontSize="48" Foreground="#8C96A8" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource NoNotificationsTitle}" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource NoNotificationsSubtitle}" 
                           FontSize="12" 
                           Foreground="#8C96A8" 
                           Margin="0,4,0,0" 
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ListView of Notifications -->
            <ListView x:Name="LstNotifications" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      SelectionMode="Single"
                      SelectionChanged="LstNotifications_SelectionChanged">
                
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- Card Border with dynamic opacity/colors based on Read/Unread state -->
                        <Border CornerRadius="8" 
                                Background="#FF1E2837" 
                                BorderThickness="1" 
                                Margin="2,4" 
                                Padding="12,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRead}" Value="False">
                                            <!-- Highlight unread notifications with Accent border -->
                                            <Setter Property="BorderBrush" Value="#4060CDFF" />
                                            <Setter Property="Background" Value="#FF243247" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF2D3F59" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Left type indicator strip -->
                                    <ColumnDefinition Width="6" />
                                    <!-- Icon -->
                                    <ColumnDefinition Width="36" />
                                    <!-- Text Content -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Metadata & Actions -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Color Bar representing notification type -->
                                <Border Grid.Column="0" CornerRadius="3" Margin="0,2,0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Alarm">
                                                    <Setter Property="Background" Value="#EF5350" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Death">
                                                    <Setter Property="Background" Value="#FF7043" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Chat">
                                                    <Setter Property="Background" Value="#42A5F5" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Pairing">
                                                    <Setter Property="Background" Value="#66BB6A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Notification Type Icon -->
                                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Standard SymbolIcon depending on Type -->
                                    <ui:SymbolIcon FontSize="18">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Alarm">
                                                        <Setter Property="Symbol" Value="Warning24" />
                                                        <Setter Property="Foreground" Value="#EF5350" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Death">
                                                        <Setter Property="Symbol" Value="HeartPulse24" />
                                                        <Setter Property="Foreground" Value="#FF7043" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Chat">
                                                        <Setter Property="Symbol" Value="Mail24" />
                                                        <Setter Property="Foreground" Value="#42A5F5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Pairing">
                                                        <Setter Property="Symbol" Value="BluetoothConnected24" />
                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                    
                                    <!-- Unread blue dot -->
                                    <Ellipse Width="6" Height="6" 
                                             Fill="#60CDFF" 
                                             Stroke="#FF243247" 
                                             StrokeThickness="1"
                                             HorizontalAlignment="Right" 
                                             VerticalAlignment="Top" 
                                             Margin="0,0,-2,-2"
                                             Visibility="{Binding IsRead, Converter={StaticResource VisInv}}" />
                                </Grid>

                                <!-- Text Message Content -->
                                <StackPanel Grid.Column="2" Margin="10,0,10,0" VerticalAlignment="Center">
                                    <!-- Title -->
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="13" 
                                               FontWeight="Bold" 
                                               Foreground="White"
                                               TextTrimming="None"
                                               TextWrapping="Wrap" />
                                    
                                    <!-- Message body -->
                                    <TextBlock Text="{Binding Message}" 
                                               FontSize="11" 
                                               Foreground="#8C96A8" 
                                               Margin="0,3,0,0" 
                                               TextTrimming="None"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Timestamp, Server Link and Actions -->
                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Short Timestamp -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="{Binding Timestamp, StringFormat='{}{0:MM/dd HH:mm}'}" 
                                               FontSize="10" 
                                               Foreground="#5A6475" 
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                     <!-- Server Tag (if available) -->
                                     <ui:Button Grid.Row="1" Grid.Column="0" 
                                                Click="BtnServerTag_Click"
                                                Tag="{Binding}" 
                                                Padding="6,2" 
                                                Height="20" 
                                                Margin="0,4,8,0"
                                                Appearance="Secondary"
                                                HorizontalAlignment="Right">
                                         <ui:Button.Style>
                                             <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding ServerIp, Converter={StaticResource NotNull}}" Value="True">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </ui:Button.Style>
                                         <TextBlock FontSize="9" Foreground="#60CDFF" FontWeight="SemiBold">
                                             <TextBlock.Text>
                                                 <PriorityBinding>
                                                     <Binding Path="ServerName" />
                                                     <Binding Path="ServerIp" />
                                                 </PriorityBinding>
                                             </TextBlock.Text>
                                         </TextBlock>
                                     </ui:Button>
 
                                     <!-- Action Button: Delete -->
                                     <ui:Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" 
                                                Click="BtnDelete_Click" 
                                                Tag="{Binding Id}"
                                                Appearance="Transparent"
                                                Width="28" Height="28"
                                                Padding="0"
                                                VerticalAlignment="Center">
                                         <ui:SymbolIcon Symbol="Delete24" FontSize="14" Foreground="#8C96A8"/>
                                     </ui:Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
