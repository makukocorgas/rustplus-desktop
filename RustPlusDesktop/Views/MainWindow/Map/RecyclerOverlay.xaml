<UserControl x:Class="RustPlusDesk.Views.RecyclerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="540" d:DesignWidth="450"
             Background="Transparent">

    <Border Background="#F9111317" BorderBrush="#25FFFFFF" BorderThickness="1" CornerRadius="12" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.6" ShadowDepth="0" />
        </Border.Effect>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Calculator24" FontSize="18" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" />
                    <TextBlock Text="Recycling Calculator" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
                <ui:Button HorizontalAlignment="Right" VerticalAlignment="Center" Padding="4" Appearance="Transparent" Click="BtnClose_Click" Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
            </Grid>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="265" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Inputs (Left Column) -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="4,0,4,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="105" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="SearchTextBox" 
                                    Grid.Column="0"
                                    PlaceholderText="Search..." 
                                    Icon="Search24"
                                    Background="#1A1D24"
                                    BorderBrush="#25FFFFFF"
                                    Foreground="White"
                                    FontSize="11.5"
                                    Margin="0,0,4,0"
                                    Height="28"
                                    Padding="10,0,10,4"
                                    VerticalContentAlignment="Center"
                                    TextChanged="SearchTextBox_TextChanged" />

                        <ComboBox x:Name="CategoryComboBox"
                                  Grid.Column="1"
                                  Background="#1A1D24"
                                  BorderBrush="#25FFFFFF"
                                  Foreground="White"
                                  FontSize="11.5"
                                  Height="28"
                                  Padding="6,2"
                                  SelectionChanged="CategoryComboBox_SelectionChanged" />
                    </Grid>

                    <ScrollViewer x:Name="InputsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  ScrollChanged="InputsScrollViewer_ScrollChanged">
                        <ItemsControl x:Name="InputsControl" Margin="0,0,4,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#131518" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="6" Width="56" Height="78" Margin="2"
                                            PreviewMouseWheel="ItemCard_MouseWheel"
                                            PreviewMouseLeftButtonDown="ItemCard_LeftClick"
                                            PreviewMouseRightButtonDown="ItemCard_RightClick"
                                            ToolTipService.InitialShowDelay="200">
                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="{Binding DisplayName}" Background="#1F2228" Foreground="White" BorderBrush="#25FFFFFF" />
                                        </ToolTipService.ToolTip>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Icon -->
                                            <Image Grid.Row="0" Width="32" Height="32" Source="{Binding Icon}" Margin="0,4,0,2" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />

                                            <!-- Quantity TextBox -->
                                            <ui:TextBox Grid.Row="1" 
                                                        Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        ClearButtonEnabled="False"
                                                        HorizontalContentAlignment="Center" 
                                                        VerticalContentAlignment="Center"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Height="24" 
                                                        Margin="3,0,3,3"
                                                        Padding="0,2,0,2" 
                                                        BorderThickness="1"
                                                        BorderBrush="#20FFFFFF"
                                                        Background="#0E1012"
                                                        Foreground="White"
                                                        PreviewTextInput="QuantityTextBox_PreviewTextInput"
                                                        DataObject.Pasting="QuantityTextBox_Pasting"
                                                        GotFocus="QuantityTextBox_GotFocus"
                                                        LostFocus="QuantityTextBox_LostFocus" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Separator -->
                <Border Grid.Column="1" Width="1" Background="#15FFFFFF" Margin="8,0" />

                <!-- Outputs (Right Column) -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Yield Comparison" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" Margin="2,0,0,4" />

                    <!-- Headers -->
                    <Grid Grid.Row="1" Margin="2,0,2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Wild" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center" ToolTip="100% Yield (Monuments)" />
                        <TextBlock Grid.Column="2" Text="Outpost" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center" ToolTip="Outpost/Safezone Recycler" />
                    </Grid>

                    <!-- Outputs list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="OutputsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="OutputRowBorder" Margin="0,2" Padding="4,4" CornerRadius="6" SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" /> <!-- Icon -->
                                                <ColumnDefinition Width="*" />    <!-- Name -->
                                                <ColumnDefinition Width="48" /> <!-- Wild -->
                                                <ColumnDefinition Width="48" /> <!-- Safe -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Resource Icon -->
                                            <Image Grid.Column="0" Width="20" Height="20" Source="{Binding Icon}" Margin="0,0,6,0" VerticalAlignment="Center" />

                                            <!-- Resource Name -->
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11.5" Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                                            <!-- Wild Amount -->
                                            <Border Grid.Column="2" Width="40" Height="20" Padding="2,0" Background="#163524" BorderBrush="#304ADE80" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="{Binding WildToolTip}">
                                                <TextBlock Text="{Binding WildText}" FontSize="11" FontWeight="Bold" Foreground="#FF4ADE80" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Border>

                                            <!-- Safezone Amount -->
                                            <Border Grid.Column="3" Width="40" Height="20" Padding="2,0" Background="#30241E" BorderBrush="#30FBA585" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="{Binding SafeToolTip}">
                                                <TextBlock Text="{Binding SafeText}" FontSize="11" FontWeight="Bold" Foreground="#FFFBA585" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter TargetName="OutputRowBorder" Property="Opacity" Value="0.25" />
                                            <Setter TargetName="OutputRowBorder" Property="Background" Value="Transparent" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="OutputRowBorder" Property="Background" Value="#10FFFFFF" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Bottom Action Bar -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Shift+Click / Scroll to change by 10" FontSize="10" Foreground="{DynamicResource TextSubtle}" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Time:" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtWildTime" Text="00:00:00" FontSize="11" FontWeight="Bold" Foreground="#FF4ADE80" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Wild Recycler Time"/>
                        <TextBlock x:Name="TxtSafeTime" Text="00:00:00" FontSize="11" FontWeight="Bold" Foreground="#FFFBA585" VerticalAlignment="Center" ToolTip="Outpost Recycler Time"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <ui:Button Content="Clear All" Appearance="Secondary" Padding="12,5" Click="BtnClearAll_Click" Margin="0,0,8,0" FontSize="11" />
                    <ui:Button Content="Fill Stacks" Appearance="Secondary" Padding="12,5" Click="BtnFillStacks_Click" FontSize="11" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
