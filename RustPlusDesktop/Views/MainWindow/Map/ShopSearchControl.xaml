<UserControl
    x:Class="RustPlusDesk.Views.ShopSearchControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    d:DesignHeight="540"
    d:DesignWidth="400"
    Background="Transparent"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Style 1: Glassy Pill/Capsule Button (Filters) -->
        <Style x:Key="GlassyPillButton" TargetType="Button">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#16FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#CCECEFF1" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="btnBorder" Property="BorderThickness" Value="1.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style 2: Cohesive Action Toolbar Button with Dynamic Hover Expansion -->
        <Style x:Key="ActionToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#0FFFFFFF" />
            <Setter Property="BorderBrush" Value="#10FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E0ECEFF1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#22FFFFFF"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#00adef"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#00adef"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style 3: Smooth Animated Label on Button Hover -->
        <Style x:Key="HoverTextOnlyOnParentHover" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard Timeline.DesiredFrameRate="120">
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="100"
                                                 Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="4,0,0,0"
                                                    Duration="0:0:0.25">
                                    <ThicknessAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard Timeline.DesiredFrameRate="120">
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="0"
                                                    Duration="0:0:0.2">
                                    <ThicknessAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseIn"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style 4: Alert Row Action Button -->
        <Style x:Key="AlertActionButton" TargetType="Button">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#16FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#CCECEFF1" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="NativeShopSearch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Search & Integrated Action Toolbar -->
        <Grid Grid.Row="0" Margin="10,12,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Magnified Glassy Search Box inside capsule Border -->
            <Border Grid.Column="0"
                    Background="#1A1D24"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Height="36"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center">
                <Grid>
                    <ui:TextBox
                        x:Name="TxtShopSearch"
                        PlaceholderText="Search items or type freely..."
                        TextChanged="TxtShopSearch_TextChanged"
                        PreviewKeyDown="TxtShopSearch_PreviewKeyDown"
                        GotFocus="TxtShopSearch_GotFocus"
                        LostFocus="TxtShopSearch_LostFocus"
                        Icon="Search24"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="13.5"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        Padding="6,0,6,0" />

                    <!-- Auto-complete Suggestions popup -->
                    <Popup
                        x:Name="PopupAutocomplete"
                        PlacementTarget="{Binding ElementName=TxtShopSearch}"
                        Placement="Bottom"
                        IsOpen="False"
                        StaysOpen="False"
                        MinWidth="240"
                        MaxHeight="200"
                        PopupAnimation="Fade">
                        <Border
                            Background="#16191E"
                            BorderBrush="#35FFFFFF"
                            BorderThickness="1"
                            CornerRadius="6">
                            <ListBox
                                x:Name="LstAutocomplete"
                                Background="Transparent"
                                BorderThickness="0"
                                MaxHeight="190"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                SelectionChanged="LstAutocomplete_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Width="16" Height="16" Margin="0,0,8,0" Source="{Binding Icon}" RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock Text="{Binding Display}" Foreground="White" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- Integrated Action Buttons with dynamic hover expansion -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button
                    x:Name="BtnShopProfit"
                    Style="{StaticResource ActionToolbarButton}"
                    Click="BtnShopProfit_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4B0;" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text=" Profit" Style="{StaticResource HoverTextOnlyOnParentHover}"/>
                    </StackPanel>
                </Button>

                <Button
                    x:Name="BtnShopBuyX"
                    Style="{StaticResource ActionToolbarButton}"
                    Click="BtnShopBuyX_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text=" Buy X" Style="{StaticResource HoverTextOnlyOnParentHover}"/>
                    </StackPanel>
                </Button>

                <Button
                    x:Name="BtnShopAddAlert"
                    Style="{StaticResource ActionToolbarButton}"
                    Margin="0"
                    Click="BtnShopAddAlert_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F514;" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text=" Alert" Style="{StaticResource HoverTextOnlyOnParentHover}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Glassy Filter Pill Toggles flowing naturally -->
        <WrapPanel Grid.Row="1" Margin="10,2,10,4" Orientation="Horizontal">
            <Button
                x:Name="TglShopSells"
                Style="{StaticResource GlassyPillButton}"
                Click="TglShopSells_Click"
                Margin="0,0,6,6"
                ToolTip="Show shops that sell item">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💰 " FontSize="10.5" VerticalAlignment="Center" />
                    <TextBlock Text="Sells" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                x:Name="TglShopBuys"
                Style="{StaticResource GlassyPillButton}"
                Click="TglShopBuys_Click"
                Margin="0,0,6,6"
                ToolTip="Show shops that buy item">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛒 " FontSize="10.5" VerticalAlignment="Center" />
                    <TextBlock Text="Buys" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                x:Name="TglShopHideZero"
                Style="{StaticResource GlassyPillButton}"
                Click="TglShopHideZero_Click"
                Margin="0,0,0,6"
                ToolTip="Don't show offers without stock">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👁 " FontSize="10.5" VerticalAlignment="Center" />
                    <TextBlock Text="Hide 0-stock" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Row 2: Sorting and Grouping -->
        <Grid Grid.Row="2" Margin="10,2,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <TextBlock Text="Sort by" Foreground="#80ECEFF1" FontSize="10" Margin="2,0,0,4"/>
                <ComboBox x:Name="CmbSort" SelectionChanged="CmbSort_SelectionChanged" Height="34">
                    <ComboBoxItem Content="Default" Tag="default" IsSelected="True"/>
                    <ComboBoxItem Content="Price (Low to High)" Tag="price_asc"/>
                    <ComboBoxItem Content="Price (High to Low)" Tag="price_desc"/>
                    <ComboBoxItem Content="Stock" Tag="stock"/>
                    <ComboBoxItem Content="Currency" Tag="currency"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                <TextBlock Text="Payment Resource" Foreground="#80ECEFF1" FontSize="10" Margin="2,0,0,4"/>
                <ComboBox x:Name="CmbResource" SelectionChanged="CmbResource_SelectionChanged" Height="34">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Row 3: Collapsible Active Item Alerts Widget Header -->
        <Border
            Grid.Row="3"
            Margin="10,2,10,2"
            Background="#12151B"
            BorderBrush="#25FFFFFF"
            BorderThickness="1"
            CornerRadius="6"
            Cursor="Hand"
            Padding="0"
            MouseDown="AlertHdr_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Glowing Amber Left Accent Bar -->
                <Border
                    Grid.Column="0"
                    Width="4"
                    Background="#FFB74D"
                    CornerRadius="3,0,0,3"
                    Height="24"
                    VerticalAlignment="Stretch" />

                <Border Grid.Column="1" Padding="10,5">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚨 " FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Active Item Alerts" FontWeight="Bold" Foreground="#ECEFF1" FontSize="12.5" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            x:Name="TxtAlertArrow"
                            Text="▼"
                            Foreground="#CCECEFF1"
                            FontSize="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Row 4: Collapsible Item Alerts List Panel -->
        <Border
            x:Name="BrdAlertListContainer"
            Grid.Row="4"
            Margin="10,0,10,4"
            Background="#0D1015"
            BorderBrush="#20FFFFFF"
            BorderThickness="1,0,1,1"
            CornerRadius="0,0,6,6"
            Visibility="Collapsed">
            <ListBox
                x:Name="LstItemAlerts"
                MaxHeight="120"
                Background="Transparent"
                BorderThickness="0"
                Padding="6"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <!-- Rebuilt dynamically in code-behind -->
            </ListBox>
        </Border>

        <!-- Row 5: Redesigned Scrollable Shop Results -->
        <ScrollViewer
            Grid.Row="5"
            Margin="10,4,10,6"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ShopSearchResultsContainer" />
        </ScrollViewer>
    </Grid>
</UserControl>
