<UserControl x:Class="RustPlusDesk.Views.LogicEngineOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:RustPlusDesk.Converters"
             xmlns:services="clr-namespace:RustPlusDesk.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Background="{DynamicResource Surface}"
             Foreground="{DynamicResource TextPrimary}"
             d:DesignHeight="800" d:DesignWidth="600">

    <UserControl.Resources>
        <conv:DeviceFilterConverter x:Key="DeviceFilterConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" Invert="True" />
        <conv:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibilityConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToInvertedVisibilityConverter" Invert="True" />
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DeveloperBoard24" Margin="0,0,8,0" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" FontSize="14"/>
                    <TextBlock Text="Logic Engine" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                </StackPanel>
                <Button x:Name="BtnCloseLogicEngine" Content="&#x2715;" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="12" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnCloseLogicEngine_Click" />
            </Grid>
        </Border>

        <!-- Main Panel -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Actions top card -->
            <Border Style="{StaticResource Card}" Margin="12,12,12,0" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:ToggleSwitch x:Name="ToggleEngineActive" Content="Engine Active (Play/Stop)" 
                                          IsChecked="{Binding Selected.IsLogicEngineActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="ToggleEngineActive_StateChanged" Unchecked="ToggleEngineActive_StateChanged"/>
                    </StackPanel>

                    <ui:Button Grid.Column="1" Click="BtnAddRule_Click" Appearance="Primary" Content="Add Rule" Icon="{ui:SymbolIcon Symbol=Add24}"/>
                </Grid>
            </Border>

            <!-- Runtime Status Panel -->
            <Border Style="{StaticResource Card}" Margin="12,0,12,12" Grid.Row="1" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource Accent}" BorderThickness="1,0,0,0">
                <Grid DataContext="{Binding Source={x:Static services:LogicEngineRuntimeService.Instance}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,8,0" Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                        <TextBlock Text="Logic Engine Runtime" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4" Background="{DynamicResource Accent}" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="RUNNING" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Visibility="{Binding IsRunning, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <TextBlock Text="IDLE" FontSize="10" Foreground="{DynamicResource TextSubtle}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimary}" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Run Text="Active Rule: "/>
                            <Run Text="{Binding CurrentRuleName}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSubtle}" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Run Text="Current Step: "/>
                            <Run Text="{Binding CurrentStepNumber}" FontWeight="SemiBold"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding CurrentStepType}"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Pending Queue" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding PendingRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TextPrimary}" Margin="12,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No pending rules" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontStyle="Italic" Visibility="{Binding PendingRules, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"/>
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="Stop" Appearance="Danger" Icon="{ui:SymbolIcon Symbol=Stop24}" Click="BtnStopLogicEngine_Click" IsEnabled="{Binding IsRunning}" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Rules List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="12">
                <ItemsControl x:Name="RulesItemsControl" ItemsSource="{Binding Selected.LogicRules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorder}" Background="{DynamicResource SurfaceAlt}" CornerRadius="8" Margin="0,0,0,12" Padding="12">
                                <StackPanel>
                                    <!-- Rule Header: Icon, Enable, Name, Expand, Delete -->
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon picker -->
                                        <ui:Button Grid.Column="0" Click="BtnChangeRuleIcon_Click" Tag="{Binding}" Width="32" Height="32" Padding="4" Margin="0,0,8,0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" ToolTip="Change Rule Icon">
                                            <Grid>
                                                <Image Source="{Binding CustomIcon}" Width="24" Height="24" RenderOptions.BitmapScalingMode="HighQuality" Visibility="{Binding CustomIcon, Converter={StaticResource NullToInvertedVisibilityConverter}}"/>
                                                <ui:SymbolIcon Symbol="Emoji24" Visibility="{Binding CustomIcon, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            </Grid>
                                        </ui:Button>

                                        <!-- Enabled checkbox -->
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip="Enable Rule" Margin="0,0,8,0"/>

                                        <!-- Rule name -->
                                        <ui:TextBox Grid.Column="2" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold" VerticalAlignment="Center" PlaceholderText="Rule Name"/>

                                        <!-- Expand/collapse -->
                                        <ui:Button Grid.Column="3" Click="BtnToggleRuleExpand_Click" Tag="{Binding}" Appearance="Transparent" Width="30" Height="30" Padding="0" ToolTip="Expand/Collapse" Foreground="{DynamicResource TextSubtle}">
                                            <Grid>
                                                <ui:SymbolIcon Symbol="ChevronRight24" Visibility="{Binding IsExpanded, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                                <ui:SymbolIcon Symbol="ChevronDown24" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </ui:Button>

                                        <!-- Delete Rule -->
                                        <Grid Grid.Column="4">
                                            <ui:Button Click="BtnDeleteRule_Click" Tag="{Binding}" Appearance="Transparent" Width="30" Height="30" Padding="0" ToolTip="Delete Rule" Foreground="IndianRed" Visibility="{Binding IsConfirmingDelete, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                                                <ui:SymbolIcon Symbol="Delete20"/>
                                            </ui:Button>
                                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsConfirmingDelete, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <ui:Button Click="BtnConfirmDeleteRule_Click" Tag="{Binding}" Appearance="Danger" Width="30" Height="30" Padding="0" ToolTip="Confirm Delete" Margin="0,0,4,0">
                                                    <ui:SymbolIcon Symbol="Checkmark20"/>
                                                </ui:Button>
                                                <ui:Button Click="BtnCancelDeleteRule_Click" Tag="{Binding}" Appearance="Secondary" Width="30" Height="30" Padding="0" ToolTip="Cancel">
                                                    <ui:SymbolIcon Symbol="Dismiss20"/>
                                                </ui:Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <!-- Rule Details -->
                                    <Grid Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Separator Background="{DynamicResource CardBorder}" Margin="0,8,0,8"/>

                                            <!-- Rule Trigger Config -->
                                    <TextBlock Text="Trigger Event" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                    <WrapPanel Margin="0,0,0,8" VerticalAlignment="Center">
                                        <!-- Trigger Type -->
                                        <ComboBox SelectedValue="{Binding TriggerType, Mode=TwoWay}" SelectedValuePath="Tag" Width="130" Margin="0,0,8,4">
                                            <ComboBoxItem Content="Smart Alarm" Tag="SmartAlarm"/>
                                            <ComboBoxItem Content="Smart Switch" Tag="SmartSwitch"/>
                                            <ComboBoxItem Content="Chat Command" Tag="ChatCommand"/>
                                         </ComboBox>

                                         <!-- Trigger Details -->
                                         <!-- If Alarm -->
                                         <ComboBox x:Name="CmbTriggerDeviceAlarm" Width="200" Margin="0,0,8,4"
                                                   ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource DeviceFilterConverter}, ConverterParameter=SmartAlarm}"
                                                   SelectedValue="{Binding TriggerEntityId, Mode=TwoWay}"
                                                   SelectedValuePath="EntityId" DisplayMemberPath="DisplayName">
                                             <ComboBox.Style>
                                                 <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding TriggerType}" Value="SmartAlarm">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ComboBox.Style>
                                         </ComboBox>

                                         <!-- If Switch -->
                                         <ComboBox x:Name="CmbTriggerDeviceSwitch" Width="200" Margin="0,0,8,4"
                                                   ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource DeviceFilterConverter}, ConverterParameter=SmartSwitch}"
                                                   SelectedValue="{Binding TriggerEntityId, Mode=TwoWay}"
                                                   SelectedValuePath="EntityId" DisplayMemberPath="DisplayName">
                                             <ComboBox.Style>
                                                 <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding TriggerType}" Value="SmartSwitch">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ComboBox.Style>
                                         </ComboBox>
                                         
                                         <!-- If Chat Command -->
                                         <ui:TextBox Text="{Binding TriggerCommand, Mode=TwoWay}" Width="150" Margin="0,0,8,4" PlaceholderText="e.g. NAME2" x:Name="TxtTriggerCmd">
                                             <ui:TextBox.Style>
                                                 <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding TriggerType}" Value="ChatCommand">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ui:TextBox.Style>
                                         </ui:TextBox>
 
                                         <!-- State / Value for Switch -->
                                         <ComboBox SelectedValue="{Binding TriggerState, Mode=TwoWay}" SelectedValuePath="Tag" Width="110" Margin="0,0,8,4" x:Name="CmbTriggerStateSwitch">
                                             <ComboBox.Style>
                                                 <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding TriggerType}" Value="SmartSwitch">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ComboBox.Style>
                                             <ComboBoxItem Content="Active/ON">
                                                 <ComboBoxItem.Tag>
                                                     <sys:Boolean>True</sys:Boolean>
                                                 </ComboBoxItem.Tag>
                                             </ComboBoxItem>
                                             <ComboBoxItem Content="Inactive/OFF">
                                                 <ComboBoxItem.Tag>
                                                     <sys:Boolean>False</sys:Boolean>
                                                 </ComboBoxItem.Tag>
                                             </ComboBoxItem>
                                         </ComboBox>

                                         <!-- State / Value for Alarm -->
                                         <ComboBox SelectedValue="{Binding TriggerState, Mode=TwoWay}" SelectedValuePath="Tag" Width="110" Margin="0,0,8,4" x:Name="CmbTriggerStateAlarm">
                                             <ComboBox.Style>
                                                 <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding TriggerType}" Value="SmartAlarm">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ComboBox.Style>
                                             <ComboBoxItem Content="Triggered">
                                                 <ComboBoxItem.Tag>
                                                     <sys:Boolean>True</sys:Boolean>
                                                 </ComboBoxItem.Tag>
                                             </ComboBoxItem>
                                         </ComboBox>
                                     </WrapPanel>
 
                                     <!-- Gating Condition -->
                                     <TextBlock Text="Gating Condition (Optional)" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSubtle}" Margin="0,4,0,4"/>
                                     <WrapPanel Margin="0,0,0,8" VerticalAlignment="Center">
                                         <ComboBox SelectedValue="{Binding ConditionOperator, Mode=TwoWay}" SelectedValuePath="Tag" Width="90" Margin="0,0,8,4">
                                             <ComboBoxItem Content="NONE" Tag="NONE"/>
                                             <ComboBoxItem Content="AND" Tag="AND"/>
                                             <ComboBoxItem Content="OR" Tag="OR"/>
                                         </ComboBox>
 
                                         <ComboBox x:Name="CmbConditionDevice" Width="200" Margin="0,0,8,4"
                                                   ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource DeviceFilterConverter}, ConverterParameter=SmartSwitch}"
                                                   SelectedValue="{Binding ConditionDeviceEntityId, Mode=TwoWay}"
                                                   SelectedValuePath="EntityId" DisplayMemberPath="DisplayName">
                                             <ComboBox.Style>
                                                 <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                     <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ConditionOperator}" Value="AND">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ConditionOperator}" Value="OR">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>

                                        <ComboBox SelectedValue="{Binding ConditionDeviceState, Mode=TwoWay}" SelectedValuePath="Tag" Width="100" Margin="0,0,8,4" x:Name="CmbConditionState">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ConditionOperator}" Value="AND">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ConditionOperator}" Value="OR">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                            <ComboBoxItem Content="State: ON">
                                                <ComboBoxItem.Tag>
                                                    <sys:Boolean>True</sys:Boolean>
                                                </ComboBoxItem.Tag>
                                            </ComboBoxItem>
                                            <ComboBoxItem Content="State: OFF">
                                                <ComboBoxItem.Tag>
                                                    <sys:Boolean>False</sys:Boolean>
                                                </ComboBoxItem.Tag>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </WrapPanel>

                                    <!-- Rule Steps -->
                                    <TextBlock Text="Execution Steps" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,8,0,4"/>
                                    <ItemsControl ItemsSource="{Binding Steps}" x:Name="StepsItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#12161f" CornerRadius="4" Padding="8" Margin="0,0,0,6" BorderBrush="#1C202A" BorderThickness="1">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <WrapPanel VerticalAlignment="Center">
                                                                <ComboBox SelectedValue="{Binding StepType, Mode=TwoWay}" SelectedValuePath="Tag" Width="130" Margin="0,0,8,4">
                                                                    <ComboBoxItem Content="Wait" Tag="Wait"/>
                                                                    <ComboBoxItem Content="Toggle Device" Tag="Toggle"/>
                                                                    <ComboBoxItem Content="Check Availability" Tag="CheckAvailability"/>
                                                                </ComboBox>

                                                                <!-- Wait Config -->
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,8,4" x:Name="PanelWait">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding StepType}" Value="Wait">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <ui:TextBox Text="{Binding WaitSeconds, Mode=TwoWay}" Width="60" PlaceholderText="Secs"/>
                                                                    <TextBlock Text=" seconds" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{DynamicResource TextSubtle}"/>
                                                                </StackPanel>

                                                                <!-- Toggle Config -->
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,8,4" x:Name="PanelToggle">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding StepType}" Value="Toggle">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <!-- Switches or Group Selector -->
                                                                    <ComboBox x:Name="CmbToggleDevice" Width="150" Margin="0,0,4,0"
                                                                              ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              SelectedValue="{Binding TargetEntityId, Mode=TwoWay}"
                                                                              SelectedValuePath="EntityId" DisplayMemberPath="DisplayName"/>
                                                                    <ui:TextBox Text="{Binding TargetGroupName, Mode=TwoWay}" Width="100" Margin="0,0,4,0" PlaceholderText="or Group Name"/>
                                                                    
                                                                    <ComboBox SelectedValue="{Binding ToggleState, Mode=TwoWay}" SelectedValuePath="Tag" Width="100">
                                                                        <ComboBoxItem Content="Toggle" Tag="{x:Null}"/>
                                                                        <ComboBoxItem Content="Force ON">
                                                                            <ComboBoxItem.Tag>
                                                                                <sys:Boolean>True</sys:Boolean>
                                                                            </ComboBoxItem.Tag>
                                                                        </ComboBoxItem>
                                                                        <ComboBoxItem Content="Force OFF">
                                                                            <ComboBoxItem.Tag>
                                                                                <sys:Boolean>False</sys:Boolean>
                                                                            </ComboBoxItem.Tag>
                                                                        </ComboBoxItem>
                                                                    </ComboBox>
                                                                </StackPanel>

                                                                <!-- Check Availability Config -->
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,8,4" x:Name="PanelAvailability">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding StepType}" Value="CheckAvailability">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <ComboBox x:Name="CmbAvailabilityDevice" Width="150" Margin="0,0,4,0"
                                                                              ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              SelectedValue="{Binding TargetEntityId, Mode=TwoWay}"
                                                                              SelectedValuePath="EntityId" DisplayMemberPath="DisplayName"/>
                                                                    <ComboBox SelectedValue="{Binding ConditionOperator, Mode=TwoWay}" SelectedValuePath="Tag" Width="120">
                                                                        <ComboBoxItem Content="IS OFFLINE" Tag="IS_OFFLINE"/>
                                                                        <ComboBoxItem Content="IS ONLINE" Tag="IS_ONLINE"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                            </WrapPanel>

                                                            <!-- Delete Step -->
                                                            <ui:Button Grid.Column="1" Click="BtnDeleteStep_Click" Tag="{Binding}" Appearance="Transparent" Width="24" Height="24" Padding="0" ToolTip="Delete Step" Foreground="IndianRed">
                                                                <ui:SymbolIcon Symbol="Dismiss20"/>
                                                            </ui:Button>
                                                        </Grid>

                                                        <!-- Nested Steps for CheckAvailability condition -->
                                                        <StackPanel x:Name="PanelNestedSteps" Margin="20,8,0,0">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding StepType}" Value="CheckAvailability">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="Nested Steps (If Condition Met)" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                                            <ItemsControl ItemsSource="{Binding ConditionalSteps}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,0,0,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <WrapPanel VerticalAlignment="Center">
                                                                                <ComboBox SelectedValue="{Binding StepType, Mode=TwoWay}" SelectedValuePath="Tag" Width="100" Margin="0,0,4,0">
                                                                                    <ComboBoxItem Content="Wait" Tag="Wait"/>
                                                                                    <ComboBoxItem Content="Toggle" Tag="Toggle"/>
                                                                                </ComboBox>
                                                                                
                                                                                <ui:TextBox Text="{Binding WaitSeconds, Mode=TwoWay}" Width="50" PlaceholderText="Secs" Visibility="Visible"/>
                                                                                <ComboBox SelectedValue="{Binding TargetEntityId, Mode=TwoWay}" Width="120" Margin="4,0,4,0"
                                                                                          ItemsSource="{Binding DataContext.Selected.FlatDevices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                          SelectedValuePath="EntityId" DisplayMemberPath="DisplayName" x:Name="CmbNestedToggleDevice"/>
                                                                                <ComboBox SelectedValue="{Binding ToggleState, Mode=TwoWay}" SelectedValuePath="Tag" Width="90">
                                                                                    <ComboBoxItem Content="Toggle" Tag="{x:Null}"/>
                                                                                    <ComboBoxItem Content="ON">
                                                                                        <ComboBoxItem.Tag>
                                                                                            <sys:Boolean>True</sys:Boolean>
                                                                                        </ComboBoxItem.Tag>
                                                                                    </ComboBoxItem>
                                                                                    <ComboBoxItem Content="OFF">
                                                                                        <ComboBoxItem.Tag>
                                                                                            <sys:Boolean>False</sys:Boolean>
                                                                                        </ComboBoxItem.Tag>
                                                                                    </ComboBoxItem>
                                                                                </ComboBox>
                                                                            </WrapPanel>
                                                                            <ui:Button Grid.Column="1" Click="BtnDeleteNestedStep_Click" Tag="{Binding}" Appearance="Transparent" Width="20" Height="20" Padding="0" Foreground="IndianRed">
                                                                                <ui:SymbolIcon Symbol="Dismiss16"/>
                                                                            </ui:Button>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <ui:Button Click="BtnAddNestedStep_Click" Tag="{Binding}" Content="Add Nested Action" Margin="0,4,0,0" Padding="8,2" FontSize="10" Height="22"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Add Action Button -->
                                    <ui:Button Click="BtnAddStep_Click" Tag="{Binding}" Content="Add Execution Step" Margin="0,4,0,0" Padding="8,4" FontSize="11" Icon="{ui:SymbolIcon Symbol=Add20}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
