<UserControl
    x:Class="RustPlusDesk.Views.AlarmOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border
        x:Name="AlarmOverlayBorder"
        Margin="20,20,20,130"
        Padding="16"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Background="#EE660000"
        BorderBrush="#FFFF5555"
        BorderThickness="1"
        CornerRadius="8"
        Panel.ZIndex="9998"
        Visibility="Collapsed"
        Width="360">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.3" ShadowDepth="2" Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Width="18" Height="18" Margin="0,0,8,0" Source="pack://application:,,,/Assets/icons/smartalarm.png" Stretch="Uniform" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{DynamicResource SmartAlarm}" />
                <StackPanel Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:Button x:Name="AlarmOverlayPrevBtn" Padding="4" Appearance="Transparent" Click="Prev_Click" Icon="{ui:SymbolIcon Symbol=ChevronLeft24}" />
                    <TextBlock x:Name="AlarmOverlayPagingTxt" Margin="6,0" VerticalAlignment="Center" Text="1/1" />
                    <ui:Button x:Name="AlarmOverlayNextBtn" Padding="4" Appearance="Transparent" Click="Next_Click" Icon="{ui:SymbolIcon Symbol=ChevronRight24}" />
                </StackPanel>
                <ui:Button Grid.Column="3" Padding="4" Appearance="Transparent" Click="Close_Click" Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
            </Grid>
            <TextBlock x:Name="AlarmOverlayServerTxt" Grid.Row="1" Margin="0,0,0,4" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Server Name - 14:30" />
            <TextBlock x:Name="AlarmOverlayNameTxt" Grid.Row="2" Margin="0,0,0,2" FontSize="16" FontWeight="Bold" Text="Custom Alarm Name" TextWrapping="Wrap" />
            <TextBlock x:Name="AlarmOverlayMsgTxt" Grid.Row="3" Margin="0,0,0,12" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource AlarmActivated}" TextWrapping="Wrap" />
            <CheckBox x:Name="AlarmOverlayAutoHideChk" Grid.Row="4" Content="{DynamicResource AutoHideAfter3s}" FontSize="12" IsChecked="False" Checked="AutoHide_Changed" Unchecked="AutoHide_Changed" PreviewMouseLeftButtonDown="OnAutoHideCheckBoxClick" />
        </Grid>
    </Border>
</UserControl>
