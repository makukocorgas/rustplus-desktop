<UserControl
    x:Class="RustPlusDesk.Views.DeleteConfirmationOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid
        x:Name="DeleteConfirmationRoot"
        Panel.ZIndex="10000"
        Background="#AA000000"
        IsHitTestVisible="True"
        Visibility="Collapsed">
        <Border
            Width="400"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="16">
            <StackPanel>
                <Grid Margin="0,0,0,24">
                    <Ellipse
                        Width="64"
                        Height="64"
                        Fill="#26FF4B4B" />
                    <ui:SymbolIcon
                        FontSize="32"
                        Foreground="#FFFF4B4B"
                        Symbol="Delete24" />
                </Grid>
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimary}"
                    Text="{DynamicResource DeleteServerHeader}"
                    TextAlignment="Center" />
                <TextBlock
                    x:Name="TxtDeleteConfirmation"
                    Margin="0,12,0,32"
                    FontSize="14"
                    LineHeight="20"
                    Foreground="{DynamicResource TextSubtle}"
                    Text="{DynamicResource DeleteServerConfirm}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Button
                        Grid.Column="0"
                        Padding="12"
                        HorizontalAlignment="Stretch"
                        Click="BtnCancel_Click"
                        Content="{DynamicResource Cancel}" />
                    <ui:Button
                        Grid.Column="2"
                        Padding="12"
                        HorizontalAlignment="Stretch"
                        Appearance="Primary"
                        Background="#FFFF4B4B"
                        BorderBrush="#FFFF4B4B"
                        Click="BtnConfirm_Click"
                        Content="{DynamicResource DeleteAction}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
