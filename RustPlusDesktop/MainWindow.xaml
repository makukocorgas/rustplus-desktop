                                            <StackPanel x:Name="SubscriptionStack" Orientation="Vertical" />
                                        </ScrollViewer><ui:Button
                                            x:Name="DockEditSubscriptionsButton"
                                            Margin="0,4,0,0"
                                            Padding="4"
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            Click="DockEditSubscriptionsButton_Click"
                                            ToolTip="Edit Subscriptions (Drawing Overlay)">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=SubscriptionDock}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon Symbol="Edit24" Foreground="White" FontSize="18" />
                                        </ui:Button>
