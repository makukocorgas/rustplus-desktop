                            <ui:Card
                                x:Name="FollowOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                                <Grid>
                                    <!--  Active Glow  -->
                                    <Ellipse
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="#4000C8FF">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="15" />
                                        </Ellipse.Effect>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <ui:Button
                                        x:Name="BtnFollowPlayer"
                                        Padding="4"
                                        Appearance="Transparent"
                                        Click="BtnFollowPlayer_Click"
                                        IsEnabled="{Binding Selected.IsFullConnected, FallbackValue=False}"
                                        ToolTip="{DynamicResource FollowPlayer}">
                                        <StackPanel Orientation="Horizontal">
                                            <!--  Avatar or Default Icon  -->
                                            <Grid Width="24" Height="24">
                                                <!--  Default Icon (Placeholder)  -->
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="14"
                                                    Foreground="#8D98A8"
                                                    Text="&#xE77B;">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!--  Real Avatar  -->
                                                <Image
                                                    Width="24"
                                                    Height="24"
                                                    ClipToBounds="True"
                                                    Source="{Binding FollowingPlayerAvatar}"
                                                    Stretch="UniformToFill"
                                                    RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <EllipseGeometry
                                                            Center="12,12"
                                                            RadiusX="12"
                                                            RadiusY="12" />
                                                    </Image.Clip>
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect
                                                                                BlurRadius="8"
                                                                                Opacity="0.8"
                                                                                ShadowDepth="0"
                                                                                Color="Cyan" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>

                                                <!--  Active Icon Overlay (small dot or similar if needed)  -->
                                            </Grid>

                                            <TextBlock
                                                x:Name="IconFollow"
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="10"
                                                Foreground="#8D98A8"
                                                Text="&#xE70D;" />
                                        </StackPanel>
                                        <ui:Button.ContextMenu>
                                            <ContextMenu x:Name="MenuFollowPlayer">
                                                <!--  Dynamically filled  -->
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>

                            <ui:Card
                                x:Name="MonumentsToggleOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                                <Grid>
                                    <ui:Button
                                        x:Name="BtnToggleMonumentsPanel"
                                        Padding="4"
                                        Appearance="Transparent"
                                        Click="BtnToggleMonumentsPanel_Click"
                                        IsEnabled="{Binding Selected.IsFullConnected, FallbackValue=False}"
                                        ToolTip="Toggle Monument List">
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <TextBlock
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="14"
                                                Foreground="#8D98A8"
                                                Text="&#xE707;" 
                                                VerticalAlignment="Center"/>
                                            <TextBlock
                                                Text="Monuments"
                                                Margin="6,0,4,0"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                            
                            <ui:Card
                                x:Name="WipeDeathMarkersOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">
                                <Grid>
                                    <ui:Button
                                        x:Name="BtnWipeDeathMarkers"
                                        Padding="4"
                                        Appearance="Transparent"
                                        Click="BtnWipeDeathMarkers_Click"
                                        ToolTip="{DynamicResource WipeDeathMarkers}">
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <Grid Width="14" Height="16" Margin="0,0,4,0">
                                                <Path Width="14" Height="16" Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z" Fill="IndianRed" Stretch="Uniform" Stroke="Black" StrokeThickness="1" />
                                            </Grid>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="IndianRed" FontSize="14" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                        </StackPanel>


                        <!--  LIVE EVENT DOCK & TIMER DOCK (Top Right)  -->
                        <StackPanel
                            Margin="15,45,15,15"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="100"
                            Orientation="Vertical">
                            
                            <StackPanel
                                x:Name="EventDock"
                                Orientation="Vertical" />
                            
                            <ui:Button
                                x:Name="BtnCustomTimer"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0"
                                Padding="8"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Appearance="Transparent"
                                Click="BtnCustomTimer_Click"
                                ToolTip="{DynamicResource HoverCustomTimer}">
                                <ui:SymbolIcon x:Name="IconCustomTimer" Symbol="Timer24" FontSize="20" Foreground="{DynamicResource TextPrimary}" />
                            </ui:Button>
                            
                            <Popup x:Name="PopupCustomTimer" AllowsTransparency="True" StaysOpen="False" PlacementTarget="{Binding ElementName=BtnCustomTimer}" Placement="Left" HorizontalOffset="-10">
                                <ui:Card Margin="0,0,10,10" Padding="16" MinWidth="320" MaxWidth="360" Background="#AA16181C" BorderBrush="#40FFFFFF" BorderThickness="1">
                                    <ui:Card.Resources>
                                        <Style x:Key="WpfUiToggleButtonStyle" TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            <Setter Property="Background" Value="#12FFFFFF"/>
                                            <Setter Property="BorderBrush" Value="#16FFFFFF"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Width" Value="32"/>
                                            <Setter Property="Height" Value="32"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,6,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsChecked" Value="True"/>
                                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="Background" Value="#80CDFF"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#80CDFF"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ui:Card.Resources>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ActiveTimersCategory}" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="13" />
                                        
                                        <!-- List of active timers -->
                                        <ItemsControl x:Name="ListActiveTimers">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" Margin="4,0,8,0">
                                                            <Run Text="{Binding Name}" />
                                                            <Run Text=" (" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text="{Binding PlacementTarget.DataContext.Selected.ChatCommandPrefix, RelativeSource={RelativeSource AncestorType=Popup}}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text="{Binding Command}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text=")" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding RemainingTimeText}" VerticalAlignment="Center" Margin="0,0,12,0" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                            <ToggleButton IsChecked="{Binding EnableCountdownAudio}" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play 1min countdown audio">
                                                                <ui:SymbolIcon Symbol="Hourglass24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                            </ToggleButton>
                                                            <ToggleButton IsChecked="{Binding EnableAlarmAudio}" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play loud alarm at 00:00">
                                                                <ui:SymbolIcon Symbol="Alert24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                            </ToggleButton>
                                                            <ui:Button Appearance="Transparent" Width="32" Height="32" Padding="0" Tag="{Binding Id}" Click="BtnDeleteTimer_Click" ToolTip="Delete Timer">
                                                                <ui:SymbolIcon Symbol="Dismiss24" Foreground="IndianRed" FontSize="14" />
                                                            </ui:Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Add Timer Section -->
                                        <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeDefault}" Margin="0,8,0,12" Padding="0,12,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource AddTimer}" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="13" />
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox x:Name="TxtTimerName" PlaceholderText="{DynamicResource TimerName}" TextChanged="TxtTimerName_TextChanged" Height="32" Padding="8,4" VerticalContentAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <ui:TextBox x:Name="TxtTimerHours" ClearButtonEnabled="False" PlaceholderText="hh" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                        <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0,2,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" />
                                                        <ui:TextBox x:Name="TxtTimerMinutes" ClearButtonEnabled="False" PlaceholderText="mm" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                        <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0,2,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" />
                                                        <ui:TextBox x:Name="TxtTimerSeconds" ClearButtonEnabled="False" PlaceholderText="ss" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <TextBlock x:Name="TxtTimerValidation" Foreground="IndianRed" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                                        <TextBlock Text="{Binding PlacementTarget.DataContext.Selected.ChatCommandPrefix, RelativeSource={RelativeSource AncestorType=Popup}}" Foreground="{DynamicResource TextSubtle}" FontWeight="Bold" Margin="0,0,2,0" />
                                                        <TextBlock x:Name="TxtTimerCommandPreview" Text="" Foreground="{DynamicResource TextSubtle}" />
                                                    </StackPanel>
                                                    
                                                    <ToggleButton x:Name="TglAddTimerCountdown" Grid.Column="1" IsChecked="True" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play 1min countdown audio">
                                                        <ui:SymbolIcon Symbol="Hourglass24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                    </ToggleButton>
                                                    <ToggleButton x:Name="TglAddTimerAlarm" Grid.Column="2" IsChecked="False" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play loud alarm at 00:00" Margin="0,0,10,0">
                                                        <ui:SymbolIcon Symbol="Alert24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                    </ToggleButton>

                                                    <ui:Button Grid.Column="3" x:Name="BtnAddTimer" Content="{DynamicResource AddTimer}" Appearance="Primary" Padding="14,6" Height="32" CornerRadius="5" Click="BtnAddTimer_Click" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Timer Alarm Controls -->
                                        <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeDefault}" Margin="0,8,0,0" Padding="0,12,0,0">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:Button x:Name="BtnStopTimerAlarm" Visibility="Collapsed" Appearance="Secondary" Padding="12,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnStopTimerAlarm_Click" ToolTip="Stop alarm sound">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="SpeakerMute24" Foreground="IndianRed" FontSize="16" />
                                                            <TextBlock Text="Stop" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="IndianRed" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    <ui:Button x:Name="BtnSnoozeTimerAlarm" Grid.Column="1" Visibility="Collapsed" Appearance="Secondary" Padding="12,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnSnoozeTimerAlarm_Click" ToolTip="Snooze alarm">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="ClockAlarm24" Foreground="#FFA500" FontSize="16" />
                                                            <TextBlock Text="Snooze" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#FFA500" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    
                                                    <!-- Spacer Column (Column 2) -->
                                                    
                                                    <ui:Button Grid.Column="3" Appearance="Secondary" Padding="8,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnSelectTimerCountdownAudio_Click" ToolTip="Select custom 1-minute countdown sound">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="Hourglass24" FontSize="16" />
                                                            <TextBlock Text="1min" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    <ui:Button Grid.Column="4" Appearance="Secondary" Padding="8,6" Margin="0,0,6,0" Height="32" Width="32" CornerRadius="5" Click="BtnSelectTimerAlarmAudio_Click" ToolTip="Select custom alarm sound (00:00)">
                                                        <ui:SymbolIcon Symbol="MusicNote224" FontSize="16" />
                                                    </ui:Button>
                                                    <ui:Button Grid.Column="5" Appearance="Secondary" Padding="8,6" Height="32" Width="32" CornerRadius="5" Click="BtnResetTimerAlarmAudio_Click" ToolTip="Reset sounds to default">
                                                        <ui:SymbolIcon Symbol="ArrowReset24" FontSize="16" />
                                                    </ui:Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ui:Card>
                            </Popup>
                        </StackPanel>

                        <Canvas x:Name="GridLayer" IsHitTestVisible="False" />
                        <Canvas x:Name="Overlay" IsHitTestVisible="True" />

                        <!-- Monument Navigation Panel -->
                        <Border
                            x:Name="MonumentNavPanel"
                            Width="280"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="15,70,0,15"
                            Panel.ZIndex="1050"
                            Background="#E5101217"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="0"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.6"
                                    ShadowDepth="0"
                                    Color="Black" />
                            </Border.Effect>
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <!-- Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock
                                        Text="Monuments"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        VerticalAlignment="Center"/>
                                    <Button
                                        x:Name="BtnCloseMonumentNav"
                                        Width="24"
                                        Height="24"
                                        HorizontalAlignment="Right"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Style="{StaticResource GhostButton}"
                                        Click="BtnToggleMonumentsPanel_Click"
                                        Content="&#x2715;"
                                        Foreground="#8D98A8"
                                        FontSize="12"/>
                                </Grid>
                                
                                <!-- Search Box -->
                                <ui:TextBox
                                    x:Name="TxtMonumentSearch"
                                    Grid.Row="1"
                                    PlaceholderText="Search monument..."
                                    Margin="0,0,0,10"
                                    TextChanged="TxtMonumentSearch_TextChanged" />
                                    
                                <!-- Monument List -->
                                <ScrollViewer
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="MonumentListContainer" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!--  Shop Details Panel (Clamped to Map Container)  -->
                        <Border
                            x:Name="ShopDetailsPopup"
                            Width="340"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1100"
                            Background="#1E2126"
                            BorderBrush="#60FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.6"
                                    ShadowDepth="0"
                                    Color="Black" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    x:Name="BtnCloseShopDetails"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Panel.ZIndex="10"
                                    Click="BtnCloseShopDetails_Click"
                                    Content="&#x2715;"
                                    FontSize="14"
                                    Foreground="Gray"
                                    Style="{StaticResource GhostButton}" />

                                <ScrollViewer
                                    x:Name="ShopDetailsScroll"
                                    Grid.Row="1"
                                    MaxHeight="600"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ShopDetailsContent" Margin="12,4,12,12" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Base Hover Preview Popup -->
                        <Border
                            x:Name="BaseHoverPopup"
                            Width="260"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1100"
                            Background="#1A1D21"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="Collapsed"
                            MouseEnter="BaseHoverPopup_MouseEnter"
                            MouseLeave="BaseHoverPopup_MouseLeave">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="0" Color="Black"/>
                            </Border.Effect>
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Button
                                    x:Name="BtnCloseBaseHover"
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="BtnCloseBaseHover_Click"
                                    Content="&#x00D7;"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="Gray"
                                    Style="{StaticResource GhostButton}" />

                                <StackPanel Grid.Row="0" Margin="0,0,24,0">
                                    <TextBlock x:Name="TxtBaseHoverNote"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxHeight="60"/>
                                </StackPanel>

                                <Border Grid.Row="1" x:Name="BorderBaseHoverImage" Margin="0,8,0,0" CornerRadius="6" ClipToBounds="True" Background="#10FFFFFF" Visibility="Collapsed">
                                    <Image x:Name="ImgBaseHoverScreenshot" Stretch="Uniform" MaxHeight="150"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Base Detailed Gallery Popup -->
                        <Border
                            x:Name="BaseGalleryPopup"
                            Width="540"
                            Height="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1200"
                            Background="#1A1D21"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="0" Color="Black"/>
                            </Border.Effect>
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title / Close -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Base Details" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    <Button
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Right"
                                        Click="BtnCloseBaseGallery_Click"
                                        Content="&#x00D7;"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="Gray"
                                        Style="{StaticResource GhostButton}" />
                                </DockPanel>

                                <!-- Mid Panel (Gallery & Active Image Zoom Container) -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <!-- Thumbnail Strip (left) -->
                                        <ColumnDefinition Width="70"/>
                                        <!-- Main Image View (right) -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnails List -->
                                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,6,0">
                                        <StackPanel x:Name="BaseGalleryThumbsPanel" Orientation="Vertical"/>
                                    </ScrollViewer>

                                    <!-- Main Image Zoom Area -->
                                    <Grid Grid.Column="1" x:Name="BaseGalleryMainImageArea" Background="#0C0D0F" ClipToBounds="True"
                                          MouseMove="MainImage_MouseMove" MouseLeave="MainImage_MouseLeave" MouseEnter="MainImage_MouseEnter">
                                        <Image x:Name="ImgBaseGalleryMain" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        
                                        <!-- Loupe Magnifying circular Border (lens) -->
                                        <Canvas IsHitTestVisible="False">
                                            <Border x:Name="BaseGalleryMagnifierLens" Width="150" Height="150" CornerRadius="75" BorderBrush="White" BorderThickness="2" Visibility="Collapsed" IsHitTestVisible="False">
                                                <Border.Background>
                                                    <VisualBrush x:Name="BaseGalleryMagnifierBrush" Visual="{Binding ElementName=ImgBaseGalleryMain}" ViewboxUnits="Absolute" ViewportUnits="RelativeToBoundingBox" Viewport="0,0,1,1"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" Opacity="0.5" ShadowDepth="0" Color="Black"/>
                                                </Border.Effect>
                                            </Border>
                                        </Canvas>

                                        <!-- Placeholder when no screenshots exist -->
                                        <StackPanel x:Name="BaseGalleryNoImagePlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                                            <ui:SymbolIcon Symbol="Camera24" FontSize="36" Foreground="Gray" Margin="0,0,0,8"/>
                                            <TextBlock Text="{DynamicResource BaseNoScreenshotsYet}" Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!-- Bottom Note Area -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" Background="#121417" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="8">
                                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock x:Name="TxtBaseGalleryNote" Foreground="White" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="ShopSearchPanel"
                            Width="450"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="1000"
                            Background="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="ShopSearchContent"
                                    Grid.Row="0"
                                    Panel.ZIndex="5"
                                    Height="540"
                                    Background="#D916181C"
                                    BorderBrush="#25FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    RenderTransformOrigin="0.5,1"
                                    Visibility="Collapsed"
                                    UseLayoutRounding="True"
                                    SnapsToDevicePixels="True"
                                    RenderOptions.ClearTypeHint="Enabled">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.55" Color="#000000" />
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ShopSearchScale" ScaleY="1" />
                                            <TranslateTransform x:Name="ShopSearchTranslate" Y="0" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!--  Header / Drag / Close Area  -->
                                        <Border Grid.Row="0" Background="#401E2126" CornerRadius="12,12,0,0" BorderThickness="0,0,0,1" BorderBrush="#15FFFFFF">
                                            <Grid>
                                                <StackPanel Margin="12,0,0,0" Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" Text="&#x1F6D2; " />
                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="#80FFFFFF"
                                                        Text="{DynamicResource ShopSearchTitle}" />
                                                </StackPanel>
                                                <Button
                                                    x:Name="BtnCloseShopSearch"
                                                    Width="26"
                                                    Height="26"
                                                    Margin="0,0,4,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Click="BtnCloseShopSearch_Click"
                                                    Content="&#x2715;"
                                                    Cursor="Hand"
                                                    FontSize="12"
                                                    Foreground="#99FFFFFF"
                                                    Style="{StaticResource GhostButton}"
                                                    ToolTip="{DynamicResource CloseSearch}">
                                                    <Button.Resources>
                                                        <Style BasedOn="{StaticResource GhostButton}" TargetType="Button">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="White" />
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="1">
                                            <views:ShopSearchControl 
                                                x:Name="EmbeddedShopSearch"
                                                UseLayoutRounding="True"
                                                SnapsToDevicePixels="True"
                                                RenderOptions.ClearTypeHint="Enabled" />

                                            <Grid x:Name="ShopSearchWarning" Background="#F216181C" Visibility="Collapsed">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock
                                                        Margin="0,0,0,20"
                                                        HorizontalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="#CCFFFFFF"
                                                        Text="{DynamicResource ActivateShopsFirst}" />
                                                    <Button
                                                        x:Name="BtnActivateShopPolling"
                                                        Padding="20,8"
                                                        Click="BtnActivateShopPolling_Click"
                                                        Content="{DynamicResource ActivateShopPolling}"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Style="{StaticResource DonateButton}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="BtnShopToggleBorder"
                                    Grid.Row="1"
                                    Width="160"
                                    Height="26"
                                    HorizontalAlignment="Right"
                                    Background="#16181C"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
                                    <Button
                                        x:Name="BtnShopToggle"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="BtnShopSearch_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8,8,0,0">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#30FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="12"
                                                Text="&#xE721;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{DynamicResource Shops}" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Recycling Calculator Overlay  -->
                        <views:RecyclerOverlay
                            x:Name="RecyclerOverlayPanel"
                            Width="450"
                            Height="540"
                            Margin="0,0,12,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="1005"
                            Visibility="Collapsed"
                            CloseRequested="BtnCloseRecycler_Click" />

                        <!--  Integrated Chat Overlay (Roll-up)  -->
                        <Border
                            x:Name="ChatOverlayPanel"
                            Width="450"
                            Margin="12,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="1000"
                            Background="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="ChatContentBorder"
                                    Grid.Row="0"
                                    Height="420"
                                    Background="#14171C"
                                    BorderBrush="#1F242E"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    RenderTransformOrigin="0.5,1"
                                    Visibility="Collapsed">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ChatScale" ScaleY="1" />
                                            <TranslateTransform x:Name="ChatTranslate" Y="0" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Header / Drag / Close Area  -->
                                        <Grid Grid.Row="0" Background="#1B1E24">
                                            <StackPanel Margin="12,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Chat24" Margin="0,0,8,0" FontSize="16" Foreground="{DynamicResource Accent}" />
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextPrimary}"
                                                    Text="{DynamicResource TeamChatTitle}" />
                                            </StackPanel>
                                            <ui:Button
                                                x:Name="BtnCloseChatOverlay"
                                                Width="28"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Click="BtnCloseChatOverlay_Click"
                                                Appearance="Transparent"
                                                Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                                Foreground="{DynamicResource TextSubtle}"
                                                ToolTip="{DynamicResource CloseChat}"
                                                Padding="0" />
                                        </Grid>

                                        <!--  Chat-History  -->
                                        <ListBox
                                            x:Name="ChatList"
                                            Grid.Row="1"
                                            ScrollViewer.ScrollChanged="ChatScrollViewer_ScrollChanged"
                                            PreviewMouseWheel="ChatList_PreviewMouseWheel"
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemsSource="{Binding ChatMessages, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            Padding="4,8">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,2">
                                                        <!--  Day Separator  -->
                                                        <Border
                                                            Margin="0,8"
                                                            Padding="10,4"
                                                            HorizontalAlignment="Center"
                                                            Background="#1B1E24"
                                                            BorderBrush="#10FFFFFF"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Visibility="{Binding ShowSeparator, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TextSubtle}"
                                                                Text="{Binding SeparatorText}" />
                                                        </Border>

                                                        <!--  Message Bubble Grid  -->
                                                        <Grid x:Name="MsgGrid" Margin="6,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Column 0: Left Avatar (for Me) -->
                                                            <Border x:Name="LeftAvatarBorder" Grid.Column="0" Width="26" Height="26" Margin="0,0,8,0" CornerRadius="13" ClipToBounds="True" Background="#2B303C" VerticalAlignment="Top" Visibility="Visible">
                                                                <Grid>
                                                                    <ui:SymbolIcon Symbol="Person24" Filled="True" FontSize="14" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                                                                </Grid>
                                                            </Border>

                                                            <!-- Column 1: Bubble Content -->
                                                            <StackPanel Grid.Column="1" x:Name="BubbleStack" VerticalAlignment="Top">
                                                                <!-- Sender Name & Time Metadata -->
                                                                <StackPanel x:Name="MetaStack" Orientation="Horizontal" Margin="4,0,4,2">
                                                                    <TextBlock x:Name="SenderText" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource Accent}" Text="{Binding Author}" />
                                                                    <TextBlock x:Name="TimeText" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="9" Foreground="{DynamicResource TextSubtle}" Text="{Binding Timestamp, StringFormat=HH:mm}" />
                                                                </StackPanel>

                                                                <!-- Actual Message Bubble -->
                                                                <Border x:Name="MsgBubble" Padding="10,6" CornerRadius="12,12,12,2" BorderThickness="1" Background="#22252C" BorderBrush="#323846" HorizontalAlignment="Left">
                                                                    <TextBlock Foreground="{DynamicResource TextPrimary}" Text="{Binding Text}" TextWrapping="Wrap" FontSize="12" LineHeight="16"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <!-- Column 2: Right Avatar (for Teammates) -->
                                                            <Border x:Name="RightAvatarBorder" Grid.Column="2" Width="26" Height="26" Margin="8,0,0,0" CornerRadius="13" ClipToBounds="True" Background="#2B303C" VerticalAlignment="Top" Visibility="Collapsed">
                                                                <Grid>
                                                                    <ui:SymbolIcon Symbol="Person24" Filled="True" FontSize="14" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>

                                                    <!-- Triggers to shift layout to Left vs Right based on IsMe -->
                                                    <DataTemplate.Triggers>
                                                        <!-- ME: Left Sided -->
                                                        <DataTrigger Binding="{Binding IsMe}" Value="True">
                                                            <Setter TargetName="LeftAvatarBorder" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="RightAvatarBorder" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="BubbleStack" Property="HorizontalAlignment" Value="Left" />
                                                            <Setter TargetName="MetaStack" Property="HorizontalAlignment" Value="Left" />
                                                            <Setter TargetName="MsgBubble" Property="HorizontalAlignment" Value="Left" />
                                                            <Setter TargetName="MsgBubble" Property="Background" Value="#22252C" />
                                                            <Setter TargetName="MsgBubble" Property="BorderBrush" Value="#323846" />
                                                            <Setter TargetName="MsgBubble" Property="CornerRadius" Value="12,12,12,2" />
                                                            <Setter TargetName="SenderText" Property="Foreground" Value="{DynamicResource Accent}" />
                                                        </DataTrigger>
                                                        
                                                        <!-- TEAMMATE: Right Sided -->
                                                        <DataTrigger Binding="{Binding IsMe}" Value="False">
                                                            <Setter TargetName="LeftAvatarBorder" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="RightAvatarBorder" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="BubbleStack" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="MetaStack" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="MetaStack" Property="FlowDirection" Value="RightToLeft" />
                                                            <Setter TargetName="MsgBubble" Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="MsgBubble" Property="Background" Value="#1A4D6B" />
                                                            <Setter TargetName="MsgBubble" Property="BorderBrush" Value="#2C6B91" />
                                                            <Setter TargetName="MsgBubble" Property="CornerRadius" Value="12,12,2,12" />
                                                            <Setter TargetName="SenderText" Property="Foreground" Value="#60CDFF" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <ContentPresenter />
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>

                                        <!--  Input-Bar  -->
                                        <StackPanel
                                            Grid.Row="2"
                                            Margin="0"
                                            Background="#111317">
                                            <!--  Inline Error Box  -->
                                            <Border
                                                x:Name="ChatErrorBox"
                                                Margin="12,8,12,0"
                                                Padding="8"
                                                Background="#33FF0000"
                                                BorderBrush="Red"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Visibility="Collapsed">
                                                <TextBlock
                                                    x:Name="ChatErrorText"
                                                    FontSize="11"
                                                    Foreground="White"
                                                    Text="{DynamicResource ChatErrorPlaceholder}"
                                                    TextWrapping="Wrap" />
                                            </Border>

                                            <DockPanel Margin="12,10,12,4">
                                                <ui:Button
                                                    x:Name="BtnSendChat"
                                                    Width="Auto"
                                                    Padding="12,0"
                                                    Height="36"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Bottom"
                                                    DockPanel.Dock="Right"
                                                    Click="BtnSendChat_Click"
                                                    Content="{DynamicResource Send}"
                                                    Icon="{ui:SymbolIcon Symbol=Send20}"
                                                    Appearance="Primary" />

                                                <ui:TextBox
                                                    x:Name="TxtChatInput"
                                                    PlaceholderText="{DynamicResource ChatMessagePlaceholder}"
                                                    VerticalContentAlignment="Center"
                                                    KeyDown="TxtChatInput_KeyDown"
                                                    MaxLength="128"
                                                    MaxLines="1" />
                                            </DockPanel>

                                            <ui:Button
                                                x:Name="BtnOpenChatCommands"
                                                Margin="12,0,0,8"
                                                Padding="6,4"
                                                HorizontalAlignment="Left"
                                                Appearance="Transparent"
                                                Click="BtnOpenChatCommands_Click"
                                                ToolTip="{DynamicResource ChatCommandsSettings}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource TextSubtle}"/>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource TextSubtle}"
                                                        Text="{DynamicResource ChatCommands}" />
                                                </StackPanel>
                                            </ui:Button>
                                        </StackPanel>

                                        <!--  Chat Commands Overlay  -->
                                        <views:ChatCommandsOverlay
                                            x:Name="ChatCommandsOverlay"
                                            Grid.RowSpan="3"
                                            Panel.ZIndex="2000"
                                            CloseRequested="BtnCloseChatCommands_Click"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="BtnChatToggleBorder"
                                    Grid.Row="1"
                                    Width="160"
                                    Height="26"
                                    HorizontalAlignment="Left"
                                    Background="#16181C"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
                                    <Button
                                        x:Name="BtnChatToggle"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="BtnToggleChat_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8,8,0,0">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#30FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="12"
                                                Text="&#xE8F2;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{DynamicResource TeamTab}" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>

                                                <Border
                            x:Name="OverlayToolbox"
                            Grid.Row="1"
                            Margin="8"
                            Padding="8,6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Panel.ZIndex="9000"
                            Background="#CC1E1E1E"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!--  Zeichnen  -->
                                    <Button
                                        x:Name="ToolDrawButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolDrawButton_Click"
                                        ToolTip="{DynamicResource DrawToolTip}">
                                        <Image Source="pack://application:,,,/Assets/icons/pen.png" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>

                                    <!--  Text  -->
                                    <Button
                                        x:Name="ToolTextButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolTextButton_Click"
                                        ToolTip="{DynamicResource PlaceTextToolTip}">
                                        <Image Source="pack://application:,,,/Assets/icons/text.png" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>

                                    <!--  Icons  -->
                                    <Button
                                        x:Name="ToolIconButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolIconButton_Click"
                                        ToolTip="{DynamicResource PlaceIconToolTip}">
                                        <Image Source="pack://application:,,,/Assets/icons/pin.png" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>

                                    <!--  Radierer  -->
                                    <Button
                                        x:Name="ToolEraseButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolEraseButton_Click"
                                        ToolTip="{DynamicResource EraserToolTip}">
                                        <Image Source="pack://application:,,,/Assets/icons/eraser.png" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>

                                    <Rectangle Width="1" Height="20" Margin="6,0" Fill="#40FFFFFF" VerticalAlignment="Center" />

                                    <!--  LÃƒÂ¶schen  -->
                                    <Button
                                        x:Name="ToolTrashButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolTrashButton_Click"
                                        ToolTip="{DynamicResource DeleteOverlayToolTip}">
                                        <Image Source="pack://application:,,,/Assets/icons/trash.png" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>

                                    <Button
                                        x:Name="ToolUploadButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolUploadButton_Click"
                                        ToolTip="{DynamicResource UploadOverlayToolTip}">
                                        <ui:SymbolIcon Symbol="Cloud24" Foreground="White" FontSize="18" />
                                    </Button>

                                    <!--  Manual Refresh  -->
                                    <Button
                                        x:Name="ToolRefreshOverlayButton"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Click="ToolRefreshOverlayButton_Click"
                                        ToolTip="Force Refresh All Subscriptions">
                                        <ui:SymbolIcon Symbol="ArrowCounterclockwise24" Foreground="White" FontSize="18" />
                                    </Button>

                                    <ui:Button
                                        x:Name="BtnAdminPanel"
                                        Appearance="Primary"
                                        Width="32"
                                        Height="32"
                                        Margin="2,0"
                                        Icon="{ui:SymbolIcon Symbol=Shield24, Filled=True}"
                                        Visibility="Collapsed"
                                        Click="BtnAdminPanel_Click"
                                        ToolTip="Admin Panel" />
                                </StackPanel>

                                <!-- Options Panel (Inline below) -->
                                <Grid x:Name="OverlayToolOptionsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.Resources>
                                        <!-- Shared circular color button style -->
                                        <Style x:Key="ColorCircleButton" TargetType="Button">
                                            <Setter Property="Width" Value="16"/>
                                            <Setter Property="Height" Value="16"/>
                                            <Setter Property="Margin" Value="2,0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <!-- Shared square icon selector style -->
                                        <Style x:Key="IconSelectorButton" TargetType="Button">
                                            <Setter Property="Width" Value="32"/>
                                            <Setter Property="Height" Value="32"/>
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="Padding" Value="3"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>

                                         <!-- Custom marker color button style for better UI/UX -->
                                         <Style x:Key="MarkerColorCircleButton" TargetType="Button">
                                             <Setter Property="Width" Value="24"/>
                                             <Setter Property="Height" Value="24"/>
                                             <Setter Property="Margin" Value="3,0"/>
                                             <Setter Property="BorderThickness" Value="1"/>
                                             <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                                             <Setter Property="Cursor" Value="Hand"/>
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="Button">
                                                         <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"/>
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                         </Style>
                                    </Grid.Resources>

                                    <!-- Draw Options -->
                                    <StackPanel x:Name="DrawOptionsPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                                        <TextBlock Text="Thickness:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                        <Slider x:Name="SliderDrawThickness" Width="100" Minimum="1" Maximum="20" Value="3" VerticalAlignment="Center" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderDrawThickness_ValueChanged"/>
                                        <TextBlock Text="{Binding ElementName=SliderDrawThickness, Path=Value, StringFormat={}{0:F0}px}" Width="35" VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="4,0,10,0"/>
                                        <Rectangle Width="1" Height="14" Fill="#30FFFFFF" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#EF5350" Click="DrawColorButton_Click" Tag="#EF5350"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#66BB6A" Click="DrawColorButton_Click" Tag="#66BB6A"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#42A5F5" Click="DrawColorButton_Click" Tag="#42A5F5"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#FFCA28" Click="DrawColorButton_Click" Tag="#FFCA28"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#FFFFFF" Click="DrawColorButton_Click" Tag="#FFFFFF"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#212121" Click="DrawColorButton_Click" Tag="#212121"/>
                                    </StackPanel>

                                    <!-- Text Options -->
                                    <StackPanel x:Name="TextOptionsPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                                        <TextBlock Text="Size:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                        <Slider x:Name="SliderTextSize" Width="100" Minimum="10" Maximum="60" Value="16" VerticalAlignment="Center" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderTextSize_ValueChanged"/>
                                        <TextBlock Text="{Binding ElementName=SliderTextSize, Path=Value, StringFormat={}{0:F0}pt}" Width="35" VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="4,0,10,0"/>
                                        <Rectangle Width="1" Height="14" Fill="#30FFFFFF" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#FFFFFF" Click="TextColorButton_Click" Tag="#FFFFFF"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#EF5350" Click="TextColorButton_Click" Tag="#EF5350"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#66BB6A" Click="TextColorButton_Click" Tag="#66BB6A"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#42A5F5" Click="TextColorButton_Click" Tag="#42A5F5"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#FFCA28" Click="TextColorButton_Click" Tag="#FFCA28"/>
                                        <Button Style="{StaticResource ColorCircleButton}" Background="#212121" Click="TextColorButton_Click" Tag="#212121"/>
                                    </StackPanel>

                                    <!-- Icon Options -->
                                    <StackPanel x:Name="IconOptionsPanel" Orientation="Vertical" VerticalAlignment="Center" Visibility="Collapsed">
                                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                             <TextBlock Text="Size:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                             <Slider x:Name="SliderIconSize" Width="100" Minimum="12" Maximum="64" Value="24" VerticalAlignment="Center" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderIconSize_ValueChanged"/>
                                             <TextBlock Text="{Binding ElementName=SliderIconSize, Path=Value, StringFormat={}{0:F0}px}" Width="35" VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="4,0,10,0"/>
                                             <Rectangle Width="1" Height="14" Fill="#30FFFFFF" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                             
                                             <Button x:Name="BtnIconBase1" Style="{StaticResource IconSelectorButton}" Click="IconSelection_Click" Tag="pack://application:,,,/Assets/icons/map-icons/base1.png" ToolTip="Own Base (Black)">
                                                 <Image Source="pack://application:,,,/Assets/icons/map-icons/base1.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Button>
                                             <Button x:Name="BtnIconBase2" Style="{StaticResource IconSelectorButton}" Click="IconSelection_Click" Tag="pack://application:,,,/Assets/icons/map-icons/base2.png" ToolTip="Enemy Base (Red)">
                                                 <Image Source="pack://application:,,,/Assets/icons/map-icons/base2.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Button>
                                             <Button x:Name="BtnIconSam" Style="{StaticResource IconSelectorButton}" Click="IconSelection_Click" Tag="pack://application:,,,/Assets/icons/map-icons/sam-site.png" ToolTip="SAM Site">
                                                 <Image Source="pack://application:,,,/Assets/icons/map-icons/sam-site.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Button>
                                             <Button x:Name="BtnIconTurret" Style="{StaticResource IconSelectorButton}" Click="IconSelection_Click" Tag="pack://application:,,,/Assets/icons/map-icons/turret.png" ToolTip="Turret">
                                                 <Image Source="pack://application:,,,/Assets/icons/map-icons/turret.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Button>
                                         </StackPanel>

                                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                                             <TextBlock Text="Marker:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                             <UniformGrid x:Name="RustMarkerSelectorPanel" Rows="2" Columns="6" Height="72" VerticalAlignment="Center">
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="pin" ToolTip="Pin"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="dollar" ToolTip="Dollar"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="gun" ToolTip="Gun"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="home" ToolTip="Home"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="loot" ToolTip="Loot"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="parachute" ToolTip="Parachute"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="rock" ToolTip="Rock"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="scope" ToolTip="Scope"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="shield" ToolTip="Shield"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="skull" ToolTip="Skull"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="sleep" ToolTip="Sleep"/>
                                                 <Button Style="{StaticResource IconSelectorButton}" Click="RustMarkerSelection_Click" Tag="zzz" ToolTip="ZZZ"/>
                                             </UniformGrid>
                                             <Rectangle Width="1" Height="56" Fill="#30FFFFFF" Margin="8,0,8,0" VerticalAlignment="Center"/>
                                             <TextBlock Text="Color:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                             <StackPanel x:Name="RustColorSelectorPanel" Orientation="Horizontal" VerticalAlignment="Center">
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#CDD054" Click="RustColorSelection_Click" Tag="yellow" ToolTip="Yellow"/>
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#2F71C4" Click="RustColorSelection_Click" Tag="blue" ToolTip="Blue"/>
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#76A739" Click="RustColorSelection_Click" Tag="green" ToolTip="Green"/>
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#BD3838" Click="RustColorSelection_Click" Tag="red" ToolTip="Red"/>
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#B65CC4" Click="RustColorSelection_Click" Tag="purple" ToolTip="Purple"/>
                                                 <Button Style="{StaticResource MarkerColorCircleButton}" Background="#06EDC2" Click="RustColorSelection_Click" Tag="cyan" ToolTip="Cyan"/>
                                             </StackPanel>
                                         </StackPanel>
                                     </StackPanel>

                                    <!-- Eraser Options -->
                                    <StackPanel x:Name="EraserOptionsPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                                        <TextBlock Text="Size:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                        <Slider x:Name="SliderEraserSize" Width="100" Minimum="5" Maximum="40" Value="20" VerticalAlignment="Center" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderEraserSize_ValueChanged"/>
                                        <TextBlock Text="{Binding ElementName=SliderEraserSize, Path=Value, StringFormat={}{0:F0}px}" Width="35" VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="4,0,10,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border
                            x:Name="OverlayTeamBar"
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            Padding="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="9000"
                            Background="#801E1E1E"
                            CornerRadius="6"
                            Visibility="Collapsed">
                            <StackPanel
                                x:Name="OverlayTeamStack"
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <!--  Buttons fÃƒÂ¼r Team-Mitglieder werden dynamisch in CodeBehind eingefÃƒÂ¼gt  -->
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBox
                        x:Name="TxtLog"
                        Grid.Row="2"
                        Height="100"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
            <!--  Premium Busy Overlay (Single)  -->
            <Grid
                Panel.ZIndex="9999"
                Background="#AA000000"
                IsHitTestVisible="True"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <Border
                    Width="340"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <ui:ProgressRing
                            Width="48"
                            Height="48"
                            Margin="0,0,0,20"
                            IsIndeterminate="True" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimary}"
                            Text="{Binding BusyText}"
                            TextAlignment="Center" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSubtle}"
                            Text="{DynamicResource MayTakeAMoment}"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Dedicated Login & Pairing Overlay  -->
            <Grid
                Panel.ZIndex="9998"
                Background="#DD0F1115"
                IsHitTestVisible="True"
                Visibility="{Binding ShowLoginOverlay, Converter={StaticResource BoolToVisibility}}">

                <Border
                    Width="450"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="50"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="Black" />
                    </Border.Effect>

                    <StackPanel>
                        <!--  Icon / Brand  -->
                        <Border
                            Width="80"
                            Height="80"
                            Margin="0,0,0,24"
                            Background="{DynamicResource AccentDark}"
                            CornerRadius="40">
                            <ui:SymbolIcon
                                FontSize="40"
                                Foreground="{DynamicResource Accent}"
                                Symbol="ShieldLock24" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{DynamicResource ReadyToDominate}"
                            TextAlignment="Center" />

                        <TextBlock
                            Margin="0,0,0,32"
                            FontSize="14"
                            Foreground="{DynamicResource TextSubtle}"
                            LineHeight="20"
                            Text="{DynamicResource PairAccountBenefits}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <ui:Button
                            x:Name="BtnOverlayPair"
                            Height="50"
                            HorizontalAlignment="Stretch"
                            Appearance="Primary"
                            Click="BtnOverlayPair_Click"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Icon="{ui:SymbolIcon Symbol=BluetoothConnected24}">
                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="{DynamicResource LoginPairAccount}" />
                            </ui:Button.Content>
                        </ui:Button>

                        <ui:Button
                            x:Name="BtnOverlayRestore"
                            Height="40"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Stretch"
                            Appearance="Secondary"
                            Click="BtnOverlayRestore_Click"
                            FontSize="14"
                            Icon="{ui:SymbolIcon Symbol=ArrowDownload24}">
                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="{DynamicResource RestoreData}" />
                            </ui:Button.Content>
                        </ui:Button>

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource TextCaption}"
                            Text="{DynamicResource RequiresSteamLogin}"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Delete Confirmation Overlay  -->
            <Grid
                x:Name="DeleteConfirmationOverlay"
                Panel.ZIndex="10000"
                Background="#AA000000"
                IsHitTestVisible="True"
                Visibility="Collapsed">
                <Border
                    Width="400"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel>
                        <!--  Header with Icon  -->
                        <Grid Margin="0,0,0,24">
                            <Ellipse
                                Width="64"
                                Height="64"
                                Fill="#26FF4B4B" />
                            <ui:SymbolIcon
                                FontSize="32"
                                Foreground="#FFFF4B4B"
                                Symbol="Delete24" />
                        </Grid>

                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimary}"
                            Text="{DynamicResource DeleteServerHeader}"
                            TextAlignment="Center" />

                        <TextBlock
                            x:Name="TxtDeleteConfirmation"
                            Margin="0,12,0,32"
                            FontSize="14"
                            LineHeight="20"
                            Foreground="{DynamicResource TextSubtle}"
                            Text="{DynamicResource DeleteServerConfirm}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:Button
                                Grid.Column="0"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                Click="BtnCancelDelete_Click"
                                Content="{DynamicResource Cancel}" />

                            <ui:Button
                                Grid.Column="2"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                Appearance="Primary"
                                Background="#FFFF4B4B"
                                BorderBrush="#FFFF4B4B"
                                Click="BtnConfirmDelete_Click"
                                Content="{DynamicResource DeleteAction}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Custom Smart Alarm Overlay  -->
            <Border
                x:Name="AlarmOverlayBorder"
                Grid.ColumnSpan="3"
                Margin="20,20,20,130"
                Padding="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#EE660000"
                BorderBrush="#FFFF5555"
                BorderThickness="1"
                CornerRadius="8"
                Panel.ZIndex="9998"
                Visibility="Collapsed"
                Width="360">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.3" ShadowDepth="2" Color="Black" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="18" Height="18" Margin="0,0,8,0" Source="pack://application:,,,/Assets/icons/smartalarm.png" Stretch="Uniform" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{DynamicResource SmartAlarm}" />

                        <StackPanel Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center" Orientation="Horizontal">
                            <ui:Button x:Name="AlarmOverlayPrevBtn" Padding="4" Appearance="Transparent" Click="AlarmOverlayPrev_Click" Icon="{ui:SymbolIcon Symbol=ChevronLeft24}" />
                            <TextBlock x:Name="AlarmOverlayPagingTxt" Margin="6,0" VerticalAlignment="Center" Text="1/1" />
                            <ui:Button x:Name="AlarmOverlayNextBtn" Padding="4" Appearance="Transparent" Click="AlarmOverlayNext_Click" Icon="{ui:SymbolIcon Symbol=ChevronRight24}" />
                        </StackPanel>

                        <ui:Button Grid.Column="3" Padding="4" Appearance="Transparent" Click="AlarmOverlayClose_Click" Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                    </Grid>

                    <TextBlock x:Name="AlarmOverlayServerTxt" Grid.Row="1" Margin="0,0,0,4" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Server Name - 14:30" />
                    <TextBlock x:Name="AlarmOverlayNameTxt" Grid.Row="2" Margin="0,0,0,2" FontSize="16" FontWeight="Bold" Text="Custom Alarm Name" TextWrapping="Wrap" />
                    <TextBlock x:Name="AlarmOverlayMsgTxt" Grid.Row="3" Margin="0,0,0,12" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource AlarmActivated}" TextWrapping="Wrap" />

                    <CheckBox x:Name="AlarmOverlayAutoHideChk" Grid.Row="4" Content="{DynamicResource AutoHideAfter3s}" FontSize="12" IsChecked="False" Checked="AlarmOverlayAutoHideChk_Changed" Unchecked="AlarmOverlayAutoHideChk_Changed" PreviewMouseLeftButtonDown="OnAutoHideCheckBoxClick"/>
                </Grid>
            </Border>

            <!-- Upload Consent Overlay -->
            <Grid x:Name="UploadConsentOverlay" Visibility="Collapsed" Background="#C0000000" Grid.ColumnSpan="3" Panel.ZIndex="10000">
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="450">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource UploadConsentTitle}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>
                        <TextBlock Text="{DynamicResource UploadConsentText}" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource Decline}" Margin="0,0,8,0" Padding="16,6" Click="BtnDeclineUploadConsent_Click" Background="#404040" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <ui:Button Content="{DynamicResource Accept}" Appearance="Primary" Padding="24,6" Click="BtnAcceptUploadConsent_Click" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Server Info Backdrop Overlay -->
            <Grid x:Name="ServerInfoBackdrop"
                  Grid.ColumnSpan="3"
                  Background="#990D0E11"
                  Visibility="Collapsed"
                  Panel.ZIndex="9990"
                  MouseLeftButtonDown="ServerInfoBackdrop_MouseLeftButtonDown" />

            <!--  Wpf.Ui: WinUI 3 Snackbar presenter (toast notifications)  -->
            <ui:SnackbarPresenter
                x:Name="RootSnackbar"
                Grid.ColumnSpan="3"
                Margin="20,0,20,20"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                MaxWidth="550"
                Panel.ZIndex="9999" />

        </Grid>
    </Grid>
</ui:FluentWindow>





