                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItems, ElementName=ListDevices}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Border
                                            Padding="32,24"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource Surface}"
                                             BorderBrush="{DynamicResource CardBorder}"
                                             BorderThickness="1"
                                             CornerRadius="12">
                                            <StackPanel>
                                                <ui:SymbolIcon
                                                     Symbol="Connector24"
                                                     FontSize="44"
                                                     Foreground="{DynamicResource TextSubtle}"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,0,0,12" />
                                                <TextBlock
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="#EAECEE"
                                                    Text="{DynamicResource NoDevicesFound}" />
                                                <TextBlock
                                                    MaxWidth="200"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="#7F8A96"
                                                    Text="{DynamicResource PairDeviceToSee}"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>


                                </Grid>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== TEAM =====  -->
                        <TabItem
                            x:Name="TabTeam"
                            Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="People24" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource TeamTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid Background="#181A1E">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.Resources>
                                        <conv:BoolToVisibilityConverter x:Key="Vis" />
                                        <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />
                                        <Style x:Key="Card" TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10" />
                                            <Setter Property="Background" Value="#FF141F2D" />
                                            <Setter Property="Padding" Value="8" />
                                            <Setter Property="Margin" Value="6" />
                                        </Style>
                                    </Grid.Resources>

                                    <!--  Liste oben  -->
                                    <ListBox
                                        x:Name="TeamList"
                                        Grid.Row="0"
                                        HorizontalContentAlignment="Stretch"
                                        ItemsSource="{Binding TeamMembers, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <!--  KontextmenÃ¼  -->
                                        <ListBox.Resources>
                                            <ContextMenu x:Key="TeamContextMenu" Style="{StaticResource DarkContextMenu}">
                                                <MenuItem Click="Team_Center_Click" Header="{DynamicResource CenterOnMap}" />
                                                <MenuItem Click="Team_Follow_Click" Header="{DynamicResource FollowOnMap}" />
                                                <MenuItem Click="Team_OpenProfile_Click" Header="{DynamicResource OpenSteamProfile}" />
                                                <Separator />
                                                <MenuItem Click="Team_Promote_Click" Header="{DynamicResource PromoteToLeader}" />
                                            </ContextMenu>
                                        </ListBox.Resources>

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Width" Value="210" />
                                                <!--  an deine Fensterbreite anpassen  -->
                                                <Setter Property="Margin" Value="6" />
                                                <EventSetter Event="MouseLeftButtonUp" Handler="TeamItem_MouseLeftButtonUp" />
                                                <Setter Property="ContextMenu" Value="{StaticResource TeamContextMenu}" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="56" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0" IsChecked="{Binding ShowMarkers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewMouseLeftButtonDown="TeamCheckBox_PreviewMouseLeftButtonDown" VerticalAlignment="Center" Margin="4,0,8,0" Cursor="Hand" ToolTip="Show markers on map" />

                                                        <!--  Avatar + Status  -->
                                                        <Grid Grid.Column="1" Width="44" Height="44">
                                                            <Image
                                                                ClipToBounds="True"
                                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                                Source="{Binding Avatar}"
                                                                Stretch="UniformToFill" />

                                                            <!--  Online (grÃ¼n)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#4CAF50"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource Vis}}" />

                                                            <!--  Offline (grau)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#666"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource VisInv}}" />

                                                            <!--  Leader-Stern  -->
                                                            <Path
                                                                Width="20"
                                                                Height="20"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Data="M 10,1 12,7 19,7 13,11 15,18 10,14 5,18 7,11 1,7 8,7 z"
                                                                Fill="Gold"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsLeader, Converter={StaticResource Vis}}" />
                                                            <TextBlock
                                                                Text="ðŸ’¤"
                                                                FontSize="16"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,-8,-8,0"
                                                                RenderTransformOrigin="0.5,0.5"
                                                                Visibility="{Binding IsAfk, Converter={StaticResource Vis}}">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform Angle="15" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Grid>

                                                        <!--  Textseite  -->
                                                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                            <!--  Name: Standard weiÃŸ, offline leicht ausgrauen, tot = rot  -->
                                                            <TextBlock FontSize="14" FontWeight="SemiBold">
                                                                <TextBlock.Text>
                                                                    <Binding Path="DisplayName" />
                                                                </TextBlock.Text>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="White" />
                                                                        <Setter Property="Opacity" Value="1" />
                                                                        <Style.Triggers>
                                                                            <!--  tot -> rot  -->
                                                                            <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                                                <Setter Property="Foreground" Value="#EF5350" />
                                                                            </DataTrigger>
                                                                            <!--  offline -> etwas ausgegraut  -->
                                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.55" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Opacity="0.65"
                                                                Text="{Binding DisplaySteamId}" />
                                                            <TextBlock
                                                                FontSize="10"
                                                                Foreground="#FF8C00"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding AfkText}"
                                                                Visibility="{Binding IsAfk, Converter={StaticResource Vis}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>




                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- RESPONSIVE SETTINGS GRID -->
                                    <Grid Grid.Row="1" Margin="8,4,8,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- ROW 0: Marker Toggles -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="{DynamicResource Markers}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#AAA" FontSize="11" />
                                            
                                            <!-- Profile Markers -->
                                            <CheckBox x:Name="ChkProfileMarkers" IsChecked="True" Checked="ChkProfileMarkers_Toggled" Unchecked="ChkProfileMarkers_Toggled" Margin="0,0,12,0" Style="{StaticResource DotCheckBox}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="18" Height="18" Margin="0,0,6,0" Stretch="Uniform">
                                                        <Grid Width="40" Height="40">
                                                            <!-- Real profile marker preview (lime dot with avatar) -->
                                                            <Ellipse Width="38" Height="38" Stroke="Black" StrokeThickness="2" Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibility}}">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                            <!-- Fallback if unchecked -->
                                                            <Ellipse Width="18" Height="18" Fill="LimeGreen" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                        </Grid>
                                                    </Viewbox>
                                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource Profile}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </CheckBox>

                                            <!-- Player direction arrow -->
                                            <CheckBox x:Name="ChkPlayerArrows" IsChecked="True" Checked="ChkPlayerArrows_Toggled" Unchecked="ChkPlayerArrows_Toggled" Margin="0,0,12,0" Style="{StaticResource DotCheckBox}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="18" Height="18" Margin="0,0,6,0" Stretch="Uniform">
                                                        <Grid Width="40" Height="40">
                                                            <!-- Arrow preview -->
                                                            <Path Data="M 20,4 L 32,32 L 8,32 Z" Fill="LimeGreen" Stroke="Black" StrokeThickness="2" Visibility="{Binding IsChecked, ElementName=ChkPlayerArrows, Converter={StaticResource BoolToVisibility}}" />
                                                            <!-- Fallback if unchecked -->
                                                            <Path Data="M 20,4 L 32,32 L 8,32 Z" Fill="#444" Stroke="#666" StrokeThickness="2" Visibility="{Binding IsChecked, ElementName=ChkPlayerArrows, Converter={StaticResource BoolToVisibilityInv}}" />
                                                        </Grid>
                                                    </Viewbox>
                                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource PlayerDirectionArrow}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </CheckBox>


                                            <!-- Death Markers -->
                                            <Grid x:Name="DeathMarkerToggleContainer" Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <CheckBox x:Name="ChkDeathMarkers" IsChecked="False" Checked="ChkDeathMarkers_Toggled" Unchecked="ChkDeathMarkers_Toggled" Style="{StaticResource DotCheckBox}" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Viewbox Width="18" Height="22" Margin="0,0,6,0" Stretch="Uniform">
                                                                <Grid Width="40" Height="56">
                                                                    <!-- Path matching BuildDeathPin -->
                                                                    <Path Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z" Fill="IndianRed" Stroke="Black" StrokeThickness="2" Stretch="Fill" Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}" />
                                                                    
                                                                    <!-- Avatar Circle inside the pin -->
                                                                    <Ellipse Width="26" Height="26" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="7,5,0,0" Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}">
                                                                        <Ellipse.Fill>
                                                                            <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                                        </Ellipse.Fill>
                                                                    </Ellipse>

                                                                    <!-- Checkbox unchecked state (gray dot) -->
                                                                    <Ellipse Width="16" Height="16" Fill="#444" Stroke="#666" StrokeThickness="2" Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                                </Grid>
                                                            </Viewbox>
                                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource Death}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </CheckBox>
                                                    
                                                    <ui:Button x:Name="BtnDeathMarkerSettings"
                                                               Appearance="Transparent"
                                                               Padding="2"
                                                               Margin="2,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Click="BtnDeathMarkerSettings_Click">
                                                        <ui:SymbolIcon Symbol="Settings24" FontSize="12" Foreground="#AAA" />
                                                        <ui:Button.Style>
                                                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                                <Setter Property="Opacity" Value="0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=DeathMarkerToggleContainer}" Value="True">
                                                                        <Setter Property="Opacity" Value="1" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                    </ui:Button>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- ROW 1: Streamer Mode + Icon Scale -->
                                        <Grid Grid.Row="1" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Abbreviate Names Toggle -->
                                            <ToggleButton Grid.Column="0" x:Name="BtnAbbreviateNames" Margin="0,0,10,0" Width="24" Height="24" ToolTip="{DynamicResource StreamerMode}" Checked="BtnAbbreviateNames_Toggled" Unchecked="BtnAbbreviateNames_Toggled">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#444"/>
                                                        <Setter Property="Foreground" Value="#CCC"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#222"/></Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Background" Value="#1C4B82"/>
                                                                <Setter Property="BorderBrush" Value="#2A6CA6"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                                <TextBlock Text="A..." FontSize="10" FontWeight="Bold" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                            </ToggleButton>

                                            <!-- Dynamic Slider -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{DynamicResource ScaleLabel}" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#AAA" FontSize="10" />
                                                <Slider Grid.Column="1" x:Name="SliderPlayerIconSize" Minimum="0.5" Maximum="1.5" Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="SliderPlayerIconSize_ValueChanged" VerticalAlignment="Center" MinWidth="30" />
                                                <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=SliderPlayerIconSize, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#AAA" FontSize="10" Width="30" />
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!--  ===== CAMERAS =====  -->
                        <TabItem Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Video24" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource CamerasTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <DockPanel LastChildFill="True">
                                <!--  Add Camera unten rechts  -->
                                <StackPanel
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Bottom"
                                    Orientation="Horizontal">
                                    <Button x:Name="BtnAddCam" Style="{StaticResource PrimaryButton}">
                                        <StackPanel Margin="6,1" Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" Text="ðŸ“· " />
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource AddCamera}" />
                                        </StackPanel>
                                    </Button>                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <ItemsControl x:Name="CamItems">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel ItemHeight="180" ItemWidth="220" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <StackPanel
                                            Margin="0,50"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasItems, ElementName=CamItems}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontStyle="Italic"
                                                Foreground="{StaticResource TextSubtle}"
                                                Text="{DynamicResource NoCamerasFound}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{StaticResource TextSubtle}"
                                                Opacity="0.6"
                                                Text="{DynamicResource PairCameraToSee}" />
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== PLAYERS =====  -->
                        <TabItem Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Globe24" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource PlayersTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <views:PlayersTabContent x:Name="PlayersTab" x:FieldModifier="public" />
                        </TabItem>

                        <!--  ===== NOTIFICATIONS =====  -->
                        <TabItem Style="{StaticResource PrettyTabItem}" x:Name="NotificationsTab">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Alert24" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                    <TextBlock VerticalAlignment="Center" Text="Notifications" />
                                    
                                    <!-- Red Badge for Unread Count -->
                                    <Border x:Name="NotificationsBadge"
                                            Background="#EF5350"
                                            CornerRadius="7"
                                            Padding="4,1,4,1"
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ViewModel.UnreadNotificationsCount, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ViewModel.UnreadNotificationsCount, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ViewModel.UnreadNotificationsCount, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <views:NotificationsTabContent x:Name="NotificationsTabControl" />
                        </TabItem>
                    </TabControl>

                    </DockPanel>

                    <!--  Compact Sidebar Rail (visible when sidebar is collapsed)  -->
                    <Grid
                        x:Name="CompactSidebarRail"
                        Width="72"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource Surface}">
                        <StackPanel
                            Margin="0,14"
                            HorizontalAlignment="Center">
                            <ui:Button
                                x:Name="BtnCompactPinSidebar"
                                Width="44"
                                Height="40"
                                Margin="0,0,0,8"
                                Padding="0"
                                Appearance="Secondary"
                                Click="BtnToggleSidebarPin_Click"
                                Icon="{ui:SymbolIcon Symbol=Pin24}"
                                ToolTip="Keep sidebar unfolded" />

                            <Border
                                Width="40"
                                Height="40"
                                Margin="0,0,0,14"
                                Background="#1AFFFFFF"
                                ClipToBounds="True"
                                CornerRadius="20"
                                ToolTip="{DynamicResource SteamAccount}">
                                <Grid>
                                    <ui:SymbolIcon
                                        FontSize="20"
                                        Foreground="White"
                                        Opacity="0.4"
                                        Symbol="Person24" />
                                    <Image
                                        Source="{Binding MyAvatar}"
                                        Stretch="UniformToFill"
                                        RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                            </Border>

                            <ui:Button Width="44" Height="40" Margin="0,0,0,8" Padding="0"
                                Appearance="Secondary" Click="CompactSidebarTab_Click"
                                Icon="{ui:SymbolIcon Symbol=Connector24}" Tag="0"
                                ToolTip="{DynamicResource DevicesTab}" />
                            <ui:Button Width="44" Height="40" Margin="0,0,0,8" Padding="0"
                                Appearance="Secondary" Click="CompactSidebarTab_Click"
                                Icon="{ui:SymbolIcon Symbol=People24}" Tag="1"
                                ToolTip="{DynamicResource TeamTab}" />
                            <ui:Button Width="44" Height="40" Margin="0,0,0,8" Padding="0"
                                Appearance="Secondary" Click="CompactSidebarTab_Click"
                                Icon="{ui:SymbolIcon Symbol=Video24}" Tag="2"
                                ToolTip="{DynamicResource CamerasTab}" />
                            <ui:Button Width="44" Height="40" Margin="0,0,0,8" Padding="0"
                                Appearance="Secondary" Click="CompactSidebarTab_Click"
                                Icon="{ui:SymbolIcon Symbol=Globe24}" Tag="3"
                                ToolTip="{DynamicResource PlayersTab}" />
                            <ui:Button Width="44" Height="40" Padding="0"
                                Appearance="Secondary" Click="CompactSidebarTab_Click"
                                Icon="{ui:SymbolIcon Symbol=Alert24}" Tag="4"
                                ToolTip="{DynamicResource NotificationsTab}" />
                        </StackPanel>
                    </Grid>

                    <!--  Profit Trades Overlay  -->
                    <Border
                        x:Name="ProfitTradesPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed"
                        UseLayoutRounding="True"
                        SnapsToDevicePixels="True"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1,0,0,0">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Glassy Capsule-like Premium Header -->
                            <Border Grid.Row="0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1A2D3540" Offset="0.0"/>
                                        <GradientStop Color="#002D3540" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="12,10,12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x1F4B0;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{DynamicResource ProfitTrades}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="{DynamicResource ArbitrageOpportunities}" Foreground="{DynamicResource TextSubtle}" FontSize="10.5" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button x:Name="BtnRefreshProfitTrades" Content="&#x27F3;" Style="{DynamicResource GhostButton}" Width="30" Height="30" Padding="0" FontSize="16" Margin="0,0,6,0" ToolTip="{DynamicResource Refresh}" />
                                        <Button x:Name="BtnCloseProfitTrades" Content="&#x2715;" Style="{DynamicResource GhostButton}" Width="30" Height="30" Padding="0" FontSize="13" Foreground="{DynamicResource TextSubtle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Modern User-Friendly Filter Controls (Search + Min Profit) -->
                            <Border Grid.Row="1" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Search input -->
                                    <Border Grid.Column="0"
                                            Background="#14171C"
                                            BorderBrush="#25FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Height="32"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <ui:TextBox
                                            x:Name="TxtProfitSearch"
                                            PlaceholderText="Search items (e.g. sulfur)..."
                                            TextChanged="TxtProfitSearch_TextChanged"
                                            Icon="Search24"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            FontSize="12"
                                            VerticalAlignment="Stretch"
                                            VerticalContentAlignment="Center"
                                            Padding="6,0,6,0" />
                                    </Border>

                                    <!-- Min Profit ComboBox -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Min profit:" Foreground="{DynamicResource TextSubtle}" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <ComboBox x:Name="CmbMinProfit" SelectionChanged="CmbMinProfit_SelectionChanged" Height="32" Width="100" FontSize="11.5">
                                            <ComboBoxItem Content="Show All" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="&#x2265; 10" Tag="10"/>
                                            <ComboBoxItem Content="&#x2265; 50" Tag="50"/>
                                            <ComboBoxItem Content="&#x2265; 100" Tag="100"/>
                                            <ComboBoxItem Content="&#x2265; 500" Tag="500"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Clean List container -->
                            <ListBox x:Name="ProfitTradesList" Grid.Row="2" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Padding="12" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>

                    <!--  Buy X For Y Overlay  -->
                    <Border
                        x:Name="BuyXForYPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed"
                        UseLayoutRounding="True"
                        SnapsToDevicePixels="True"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1,0,0,0">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="130" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Glassy Capsule-like Premium Header -->
                            <Border Grid.Row="0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1A2D3540" Offset="0.0"/>
                                        <GradientStop Color="#002D3540" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="12,10,12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x1F501;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{DynamicResource BuyXForY}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Optimal multi-hop trade pathfinder" Foreground="{DynamicResource TextSubtle}" FontSize="10.5" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <ui:Button x:Name="BtnCloseBuyXForY" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="4" Appearance="Transparent" Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                                </Grid>
                            </Border>

                            <!-- Glassy Form Input Controls -->
                            <Grid Grid.Row="1" Margin="12,10,12,8" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Target/Want TextBox Card -->
                                <Grid Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <ui:TextBox
                                        x:Name="BuyXForY_WantTb"
                                        Height="34"
                                        FontSize="12"
                                        PlaceholderText="Want item (e.g. blue)..."
                                        Icon="Target24"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        ToolTip="{DynamicResource IWantToGetToolTip}" />

                                    <!-- Auto-complete Suggestions popup -->
                                    <Popup
                                        x:Name="PopupAutocomplete_Want"
                                        PlacementTarget="{Binding ElementName=BuyXForY_WantTb}"
                                        Placement="Bottom"
                                        IsOpen="False"
                                        StaysOpen="False"
                                        MinWidth="200"
                                        MaxHeight="200"
                                        PopupAnimation="Fade">
                                        <Border
                                            Background="#16191E"
                                            BorderBrush="#35FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <ListBox
                                                x:Name="LstAutocomplete_Want"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                MaxHeight="190"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="6,4" Background="Transparent">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Width="16" Height="16" Margin="0,0,8,0" Source="{Binding Icon}" RenderOptions.BitmapScalingMode="HighQuality" />
                                                                <TextBlock Text="{Binding Display}" Foreground="White" FontSize="11" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Payment/Pay TextBox Card -->
                                <Grid Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                                    <ui:TextBox
                                        x:Name="BuyXForY_PayTb"
                                        Height="34"
                                        FontSize="12"
                                        PlaceholderText="Pay item (e.g. cloth)..."
                                        Icon="Money24"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        ToolTip="{DynamicResource ICanPayWithToolTip}" />

                                    <!-- Auto-complete Suggestions popup -->
                                    <Popup
                                        x:Name="PopupAutocomplete_Pay"
                                        PlacementTarget="{Binding ElementName=BuyXForY_PayTb}"
                                        Placement="Bottom"
                                        IsOpen="False"
                                        StaysOpen="False"
                                        MinWidth="200"
                                        MaxHeight="200"
                                        PopupAnimation="Fade">
                                        <Border
                                            Background="#16191E"
                                            BorderBrush="#35FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <ListBox
                                                x:Name="LstAutocomplete_Pay"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                MaxHeight="190"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="6,4" Background="Transparent">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Width="16" Height="16" Margin="0,0,8,0" Source="{Binding Icon}" RenderOptions.BitmapScalingMode="HighQuality" />
                                                                <TextBlock Text="{Binding Display}" Foreground="White" FontSize="11" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Analyze Primary Button -->
                                <ui:Button
                                    x:Name="BuyXForY_AnalyzeBtn"
                                    Grid.Column="2"
                                    Content="{DynamicResource Analyze}"
                                    Appearance="Primary"
                                    Margin="6,0,0,0"
                                    Padding="14,0"
                                    Height="34"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    VerticalAlignment="Center" />
                            </Grid>

                            <!-- Visual Previews Sub-Cards Grid -->
                            <Grid Grid.Row="2" Margin="12,0,12,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Left Preview Box: Items to Get -->
                                <Border Grid.Column="0" Margin="0,0,4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="6">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource IWantToGet}" Foreground="{DynamicResource Accent}" FontSize="9.5" FontWeight="Bold" Margin="4,0,0,4" />
                                        <ListBox x:Name="BuyXForY_WantPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>

                                <!-- Right Preview Box: Items to Pay -->
                                <Border Grid.Column="1" Margin="4,0,0,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="6">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ICanPayWith}" Foreground="{DynamicResource Accent}" FontSize="9.5" FontWeight="Bold" Margin="4,0,0,4" />
                                        <ListBox x:Name="BuyXForY_PayPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <!-- Results Scroller list -->
                            <ListBox x:Name="BuyXForY_ResultList" Grid.Row="3" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Margin="12,4,12,10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>

                    <!--  App Settings Overlay  -->
                    <views:AppSettingsOverlay
                        x:Name="AppSettingsPanel"
                        Visibility="Collapsed" />

                    <!--  Logic Engine Overlay  -->
                    <views:LogicEngineOverlay
                        x:Name="LogicEnginePanel"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <!--  Rechte Spalte: Login/Status + WebViewHost  -->
            <Border
                Grid.Column="2"
                MinWidth="400"
                Padding="12"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1,0,0,0"
                CornerRadius="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  RE-DESIGNED MAP CONTROL BAR  -->
                    <Border
                        Grid.Row="0"
                        Margin="-12,-12,-12,0"
                        Padding="16,8"
                        Background="{DynamicResource SurfaceAlt}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Left Group: Map Filters  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextSubtle}"
                                    Opacity="0.8"
                                    Text="{DynamicResource MapFilters}" />

                                <CheckBox
                                    x:Name="ChkGrid"
                                    Margin="0,0,8,0"
                                    Checked="ChkGrid_Checked"
                                    Content="{DynamicResource Grid}"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkGrid_Checked" />
                                <CheckBox
                                    x:Name="ChkPlayers"
                                    Margin="0,0,8,0"
                                    Checked="ChkPlayers_Checked"
                                    Content="{DynamicResource PlayersOnly}"
                                    IsChecked="True"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkPlayers_Checked" />
                                <CheckBox
                                    x:Name="Monuments"
                                    Margin="0,0,8,0"
                                    Checked="Monuments_Checked"
                                    Content="{DynamicResource Monuments}"
                                    IsChecked="True"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="Monuments_Unchecked" />
                                <CheckBox
                                    x:Name="ChkShops"
                                    Margin="0,0,8,0"
                                    Checked="ChkShops_Checked"
                                    Content="{DynamicResource Shops}"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkShops_Checked" />
                                <CheckBox
                                    x:Name="ChkNoBuildZones"
                                    Margin="0,0,24,0"
                                    Checked="ChkNoBuildZones_Checked"
                                    Content="No Build"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkNoBuildZones_Checked"
                                    Visibility="Collapsed" />

                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextSubtle}"
                                    Opacity="0.8"
                                    Text="{DynamicResource ChatAlerts}" />

                                 <Border
                                     Background="#AA16181C"
                                     BorderBrush="#30FFFFFF"
                                     BorderThickness="1"
                                     CornerRadius="12"
                                     Padding="2"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="Auto" />
                                         </Grid.ColumnDefinitions>

                                         <!-- Alerts Toggle Button -->
                                         <CheckBox
                                             x:Name="ChatAnnounce"
                                             Grid.Column="0"
                                             Click="ChatAnnounce_Toggle"
                                             IsChecked="False"
                                             Margin="0"
                                             Padding="10,6"
                                             ToolTip="{DynamicResource RightClickConfigure}">
                                             <CheckBox.Style>
                                                 <Style TargetType="CheckBox">
                                                     <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
                                                     <Setter Property="Background" Value="Transparent" />
                                                     <Setter Property="Cursor" Value="Hand" />
                                                     <Setter Property="FontSize" Value="12" />
                                                     <Setter Property="FontWeight" Value="SemiBold" />
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="CheckBox">
                                                                 <Border
                                                                     x:Name="Bd"
                                                                     Background="{TemplateBinding Background}"
                                                                     CornerRadius="10,0,0,10"
                                                                     Padding="{TemplateBinding Padding}"
                                                                     SnapsToDevicePixels="True">
                                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                 </Border>
                                                                 <ControlTemplate.Triggers>
                                                                     <Trigger Property="IsChecked" Value="True">
                                                                         <Setter TargetName="Bd" Property="Background" Value="#3D4B5C" />
                                                                         <Setter Property="Foreground" Value="White" />
                                                                         <Setter TargetName="Bd" Property="Effect">
                                                                             <Setter.Value>
                                                                                 <DropShadowEffect BlurRadius="8" Color="#60CDFF" Opacity="0.3" ShadowDepth="0" />
                                                                             </Setter.Value>
                                                                         </Setter>
                                                                     </Trigger>
                                                                     <Trigger Property="IsMouseOver" Value="True">
                                                                         <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                                                                     </Trigger>
                                                                 </ControlTemplate.Triggers>
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </Style>
                                             </CheckBox.Style>
                                     <CheckBox.ContextMenu>
                                         <ContextMenu Style="{StaticResource DarkContextMenu}">
                                             <MenuItem
                                                 Click="SelectAllAlerts_Click"
                                                 Header="{DynamicResource SelectAll}"
                                                 Style="{StaticResource DarkMenuItem}">
                                                 <MenuItem.Icon>
                                                     <ui:SymbolIcon Symbol="CheckmarkSquare24" />
                                                 </MenuItem.Icon>
                                             </MenuItem>
                                             <MenuItem
                                                 Click="DeselectAllAlerts_Click"
                                                 Header="{DynamicResource DeselectAll}"
                                                 Style="{StaticResource DarkMenuItem}">
                                                 <MenuItem.Icon>
                                                     <ui:SymbolIcon Symbol="DismissSquare24" />
                                                 </MenuItem.Icon>
                                             </MenuItem>
                                         </ContextMenu>
                                     </CheckBox.ContextMenu>
                                             <CheckBox.Content>
                                                 <StackPanel Orientation="Horizontal">
                                                     <ui:SymbolIcon Symbol="Alert20" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                     <TextBlock
                                                         x:Name="ChatAnnounceLabel"
                                                         VerticalAlignment="Center"
                                                         Text="{DynamicResource Alerts}" />
                                                 </StackPanel>
                                             </CheckBox.Content>
                                         </CheckBox>

                                         <!-- Vertical Separator -->
                                         <Border
                                             Grid.Column="1"
                                             Width="1"
                                             Background="#20FFFFFF"
                                             Margin="0,4"
                                             VerticalAlignment="Stretch" />

                                         <!-- Chat Alerts Dropdown -->
                                         <ui:DropDownButton
                                             x:Name="ChatAlertsConfigureButton"
                                             Grid.Column="2"
                                             Margin="0"
                                             Padding="8,6,10,6"
                                             Height="30"
                                             VerticalAlignment="Center"
                                             ToolTip="{DynamicResource Configure}"
                                             Icon="{ui:SymbolIcon Symbol=Settings20}">
                                             <ui:DropDownButton.Style>
                                                 <Style TargetType="ui:DropDownButton" BasedOn="{StaticResource {x:Type ui:DropDownButton}}">
                                                     <Setter Property="Background" Value="Transparent" />
                                                     <Setter Property="BorderBrush" Value="Transparent" />
                                                     <Setter Property="BorderThickness" Value="0" />
                                                     <Setter Property="CornerRadius" Value="0,10,10,0" />
                                                     <Style.Triggers>
                                                         <Trigger Property="IsMouseOver" Value="True">
                                                             <Setter Property="Background" Value="#1AFFFFFF" />
                                                             <Setter Property="BorderBrush" Value="Transparent" />
                                                         </Trigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ui:DropDownButton.Style>
                                             <ui:DropDownButton.Flyout>
                                                 <ContextMenu Placement="Custom" CustomPopupPlacementCallback="CenterMegaMenu_Callback">
                                                     <ContextMenu.Style>
                                                         <Style TargetType="ContextMenu" BasedOn="{StaticResource DarkContextMenu}">
                                                             <Setter Property="Template">
                                                                 <Setter.Value>
                                                                     <ControlTemplate TargetType="ContextMenu">
                                                                         <Border
                                                                             Padding="12,10"
                                                                             Background="{TemplateBinding Background}"
                                                                             BorderBrush="{DynamicResource CardBorder}"
                                                                             BorderThickness="1"
                                                                             CornerRadius="{DynamicResource Radius}"
                                                                             SnapsToDevicePixels="True">
                                                                             <StackPanel Orientation="Vertical">
                                                                                 <!-- Top Row: Quick Actions -->
                                                                                 <Grid Margin="4,2,4,8">
                                                                                      <Grid.ColumnDefinitions>
                                                                                          <ColumnDefinition Width="*" />
                                                                                          <ColumnDefinition Width="6" />
                                                                                          <ColumnDefinition Width="*" />
                                                                                          <ColumnDefinition Width="6" />
                                                                                          <ColumnDefinition Width="Auto" />
                                                                                      </Grid.ColumnDefinitions>
                                                                                      
                                                                                      <ui:Button
                                                                                          Grid.Column="0"
                                                                                          Content="{DynamicResource SelectAll}"
                                                                                          Click="SelectAllAlerts_Click"
                                                                                          Appearance="Secondary"
                                                                                          HorizontalAlignment="Stretch">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="CheckmarkSquare24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>
                                                                                      
                                                                                      <ui:Button
                                                                                          Grid.Column="2"
                                                                                          Content="{DynamicResource DeselectAll}"
                                                                                          Click="DeselectAllAlerts_Click"
                                                                                          Appearance="Secondary"
                                                                                          HorizontalAlignment="Stretch">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="DismissSquare24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>

                                                                                      <ui:Button
                                                                                          Grid.Column="4"
                                                                                          Click="EditAlertTemplates_Click"
                                                                                          Appearance="Secondary"
                                                                                          Padding="8,6"
                                                                                          ToolTip="{DynamicResource CustomizeChatAlertsToolTip}">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="Edit24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>
                                                                                  </Grid>
                                                                                 
                                                                                 <!-- Horizontal Separator -->
                                                                                 <Border BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10" />
                                                                                 
                                                                                 <!-- Categorized Items Host -->
                                                                                 <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                                                                             </StackPanel>
                                                                         </Border>
                                                                     </ControlTemplate>
                                                                 </Setter.Value>
                                                             </Setter>
                                                         </Style>
                                                     </ContextMenu.Style>

                                                     <!-- Column 1: Events -->
                                                     <MenuItem Header="{DynamicResource Events}" BorderThickness="0,0,1,0">
                                                         <MenuItem.Style>
                                                             <Style TargetType="MenuItem">
                                                                 <Setter Property="Template">
                                                                     <Setter.Value>
                                                                         <ControlTemplate TargetType="MenuItem">
                                                                             <Border
                                                                                 BorderBrush="#15FFFFFF"
                                                                                 BorderThickness="{TemplateBinding BorderThickness}"
                                                                                 Margin="0,0,12,0"
                                                                                 Padding="0,0,12,0">
                                                                                 <StackPanel Width="180">
                                                                                     <TextBlock
                                                                                         Text="{TemplateBinding Header}"
                                                                                         FontSize="11"
                                                                                         FontWeight="Bold"
                                                                                         Foreground="{DynamicResource TextSubtle}"
                                                                                         Opacity="0.8"
                                                                                         Margin="8,4,8,8" />
                                                                                     <ItemsPresenter />
                                                                                 </StackPanel>
                                                                             </Border>
                                                                         </ControlTemplate>
                                                                     </Setter.Value>
                                                                 </Setter>
                                                             </Style>
                                                         </MenuItem.Style>

                                                         <MenuItem
                                                             Header="{DynamicResource CargoShip}"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Cargo">
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoSpawn}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoSpawn" />
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoDock}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoDock" />
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoEgress}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoEgress" />
                                                             <MenuItem
                                                                 x:Name="MenuCargoArrival"
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoArrival}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoArrival" />
                                                         </MenuItem>
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Heli}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Heli" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Chinook}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Chinook" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Vendor}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Vendor" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource OilRig}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="OilRig" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
